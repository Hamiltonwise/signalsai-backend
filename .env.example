# ── Alloro Environment Variables ──────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
JWT_SECRET=your-jwt-secret-here
INTERNAL_API_KEY=your-internal-api-key-here
SUPER_ADMIN_EMAILS=info@getalloro.com

# ── Database (PostgreSQL) ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=appdb
DB_DEBUG=false
ENABLE_POOL_MONITORING=false

# ── Google OAuth + APIs ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_PLACES_API=your-google-places-api-key
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ── Redis / BullMQ ──────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TLS=false

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_HEALTH_PRICE_ID=price_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── AI / LLM ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-proj-xxx
GEMINI_API_KEY=your-gemini-key
MINDS_LLM_MODEL=claude-sonnet-4-6
MINDS_MAX_BRAIN_CHARACTERS=500000
MINDS_MAX_SCRAPED_PAGE_CHARACTERS=100000
MINDS_MAX_POSTS_PER_SCRAPE_RUN=10
MINDS_HTTP_FETCH_TIMEOUT_MS=10000

# ── Notion ───────────────────────────────────────────────────────────
NOTION_TOKEN=ntn_xxx

# ── Monday.com ───────────────────────────────────────────────────────
MONDAY_API_TOKEN=your-monday-token
MONDAY_BOARD_ID=your-board-id

# ── Apify ────────────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_xxx

# ── n8n Agent Webhooks ───────────────────────────────────────────────
PROOFLINE_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/proofline-agent
COPY_COMPANION_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/copy-companion-agent
GUARDIAN_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/guardian-agent
GOVERNANCE_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/governance-agent
SUMMARY_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/summary-agent
OPPORTUNITY_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/opportunity-agent
CRO_OPTIMIZER_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/cro-optimizer-agent
REFERRAL_ENGINE_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/referral-engine-analysis-agent
IDENTIFIER_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/identifier-agent
WEB_SCRAPING_TOOL_AGENT_WEBHOOK=https://n8n.getalloro.com/webhook/website-scraping-tool
PMS_PARSER_WEBHOOK=https://n8n.getalloro.com/webhook/parse-csv
ALLORO_EMAIL_SERVICE_WEBHOOK=https://n8n.getalloro.com/webhook/alloro-email-service
ALLORO_CUSTOM_WEBSITE_EMAIL_WEBHOOK=https://n8n.getalloro.com/webhook/public-websites-email

# ── Slack ────────────────────────────────────────────────────────────
SLACK_ALLORO_BRIEF_WEBHOOK_URL=

# ── Twilio (optional) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── AWS (S3 / SES) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# ── Sentry ───────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx

# ── Site Renderer ────────────────────────────────────────────────────
SITE_RENDERER_IP=0.0.0.0
SCRAPER_API_KEY=your-scraper-key

# ── reCAPTCHA ────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# ── Contact Form ─────────────────────────────────────────────────────
CONTACT_FORM_RECIPIENTS=info@getalloro.com
CONTACT_FORM_FROM=info@getalloro.com

# ── Analytics (Rybbit) ──────────────────────────────────────────────
RYBBIT_API_URL=https://analytics.getalloro.com
RYBBIT_API_KEY=your-rybbit-key
RYBBIT_ORG_ID=your-rybbit-org-id

# ── Smoke Test (optional) ───────────────────────────────────────────
SMOKE_TEST_URL=http://localhost:3000
SMOKE_ADMIN_TOKEN=your-admin-jwt-for-smoke-tests

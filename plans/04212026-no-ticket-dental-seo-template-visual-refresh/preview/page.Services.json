    "name": "section-services-intro",
    "content": "<section class=\"alloro-tpl-v1-release-section-services-intro bg-white py-14 md:py-20 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6\">\n    <!-- AI-CONTENT: services-intro-card-1-title | Replace with a practice differentiator title. -->\n    <!-- AI-CONTENT: services-intro-card-1-description | Replace with a short description. -->\n    <div class=\"alloro-tpl-v1-release-section-services-intro-component-card-1 bg-gray-50 rounded-3xl p-8 border border-gray-100 flex flex-col gap-4\">\n      <div class=\"w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0 bg-black/[0.07]\">\n        <svg class=\"w-6 h-6 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\"/></svg>\n      </div>\n      <h3 class=\"alloro-tpl-v1-release-section-services-intro-component-card-1-title font-serif font-semibold text-gray-900 text-xl\">Comprehensive care</h3>\n      <p class=\"alloro-tpl-v1-release-section-services-intro-component-card-1-description text-gray-600 text-base leading-relaxed font-sans\">From preventive cleanings and exams to advanced restorative and cosmetic procedures, we offer the full spectrum of dental services under one roof.</p>\n    </div>\n    <!-- AI-CONTENT: services-intro-card-2-title | Replace with a practice differentiator title. -->\n    <!-- AI-CONTENT: services-intro-card-2-description | Replace with a short description. -->\n    <div class=\"alloro-tpl-v1-release-section-services-intro-component-card-2 bg-gray-50 rounded-3xl p-8 border border-gray-100 flex flex-col gap-4\">\n      <div class=\"w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0 bg-black/[0.07]\">\n        <svg class=\"w-6 h-6 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z\"/></svg>\n      </div>\n      <h3 class=\"alloro-tpl-v1-release-section-services-intro-component-card-2-title font-serif font-semibold text-gray-900 text-xl\">Modern technology</h3>\n      <p class=\"alloro-tpl-v1-release-section-services-intro-component-card-2-description text-gray-600 text-base leading-relaxed font-sans\">Digital X-rays, intraoral cameras, and advanced diagnostic tools allow us to identify and treat issues with precision and efficiency, keeping your visits shorter and more comfortable.</p>\n    </div>\n    <!-- AI-CONTENT: services-intro-card-3-title | Replace with a practice differentiator title. -->\n    <!-- AI-CONTENT: services-intro-card-3-description | Replace with a short description. -->\n    <div class=\"alloro-tpl-v1-release-section-services-intro-component-card-3 bg-primary rounded-3xl p-8 flex flex-col gap-4\">\n      <div class=\"w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0 bg-white\">\n        <svg class=\"w-6 h-6 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z\"/></svg>\n      </div>\n      <h3 class=\"alloro-tpl-v1-release-section-services-intro-component-card-3-title font-serif font-semibold text-white text-xl\">Flexible scheduling</h3>\n      <p class=\"alloro-tpl-v1-release-section-services-intro-component-card-3-description text-sm leading-relaxed font-sans text-white/90\">We understand that life is busy. That is why we offer early morning, evening, and same-day emergency appointments to fit your schedule. Your dental health should never have to wait.</p>\n      <!-- AI-CONTENT: services-intro-card-3-cta | Replace href and phone text. -->\n      <a href=\"/contact\" class=\"alloro-tpl-v1-release-section-services-intro-component-card-3-cta inline-flex items-center gap-2 bg-white text-primary px-6 py-3 rounded-full font-medium text-sm transition-opacity hover:opacity-90 font-sans w-max mt-auto\">\n        Contact Us\n      </a>\n    </div>\n  </div>\n</section>"

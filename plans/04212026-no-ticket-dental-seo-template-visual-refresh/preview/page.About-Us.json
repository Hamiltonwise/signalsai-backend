    "name": "section-consultation-cta",
    "content": "<section class=\"alloro-tpl-v1-release-section-consultation-cta py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-gradient-brand text-ivory\">\n  <div class=\"max-w-3xl mx-auto text-center\">\n    <!-- AI-CONTENT: consultation-cta-heading | Replace with an inviting CTA heading. -->\n    <h2 class=\"alloro-tpl-v1-release-section-consultation-cta-component-heading font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-white mb-4 md:mb-6\">\n      Ready to take the next step?\n    </h2>\n    <!-- AI-CONTENT: consultation-cta-subtext | Replace with 1-2 inviting sentences. -->\n    <p class=\"alloro-tpl-v1-release-section-consultation-cta-component-subtext text-white/80 font-sans text-base md:text-lg leading-relaxed mb-8 md:mb-10 max-w-2xl mx-auto\">\n      Whether you need a routine checkup or have a specific concern, our team is here to help. Schedule your visit today and experience the difference that personalized, compassionate care can make.\n    </p>\n    <div class=\"flex flex-col sm:flex-row gap-4 justify-center\">\n      <!-- AI-CONTENT: consultation-cta-primary | Replace href and text if needed. -->\n\n      <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n\n      <a href=\"/consultation\" class=\"alloro-tpl-v1-release-section-consultation-cta-component-cta-primary inline-flex items-center justify-center gap-2 bg-primary text-white px-8 py-4 rounded-full font-medium text-base transition-opacity hover:opacity-90 font-sans\">\n        Request a Consultation\n      </a>\n      <!-- AI-CONTENT: consultation-cta-secondary | Replace href and text if needed. -->\n      <a href=\"/contact\" class=\"alloro-tpl-v1-release-section-consultation-cta-component-cta-secondary inline-flex items-center justify-center gap-2 border border-gray-300 text-white/80 px-8 py-4 rounded-full font-medium text-base transition-colors hover:border-primary hover:text-primary font-sans\">\n        Call Us Today\n      </a>\n    </div>\n  </div>\n</section>"

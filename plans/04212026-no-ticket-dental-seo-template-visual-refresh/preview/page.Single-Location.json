    "content": "<section class=\"alloro-tpl-v1-release-section-location-info bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\"><div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start\"><div><div class=\"flex items-center gap-2 mb-5\"><div class=\"h-px w-8 bg-primary\"></div><!-- AI-CONTENT: location-eyebrow | Replace with location label. Default: \"Our Location\". --><span class=\"alloro-tpl-v1-release-section-location-info-component-eyebrow text-xs font-medium tracking-[0.18em] uppercase font-sans text-primary\">Our Location</span></div><!-- AI-CONTENT: location-heading | Replace with location name. --><h2 class=\"alloro-tpl-v1-release-section-location-info-component-heading font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-medium leading-[1.1] mb-8\">Downtown Office</h2><div class=\"space-y-0\"><!-- Address --><div class=\"alloro-tpl-v1-release-section-location-info-component-address flex items-start gap-4 py-5 border-t border-gray-100\"><div class=\"w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5 bg-primary-subtle\"><svg class=\"w-5 h-5 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg></div><div><h3 class=\"font-serif font-medium text-gray-900 text-lg mb-1\">Address</h3><!-- AI-CONTENT: location-address | Replace with office street address. --><p class=\"alloro-tpl-v1-release-section-location-info-component-address-text text-gray-600 text-sm leading-relaxed font-sans\">123 Main Street, Suite 200<br>Anytown, ST 12345</p><a href=\"https://maps.google.com\" target=\"_blank\" rel=\"noreferrer\" class=\"alloro-tpl-v1-release-section-location-info-component-address-link text-primary text-sm font-medium hover:underline mt-1 inline-block font-sans\">Get Directions</a></div></div><!-- Phone --><div class=\"alloro-tpl-v1-release-section-location-info-component-phone flex items-start gap-4 py-5 border-t border-gray-100\"><div class=\"w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5 bg-primary-subtle\"><svg class=\"w-5 h-5 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z\"></path></svg></div><div><h3 class=\"font-serif font-medium text-gray-900 text-lg mb-1\">Phone</h3><!-- AI-CONTENT: location-phone | Replace with office phone number. --><a href=\"tel:5551234567\" class=\"alloro-tpl-v1-release-section-location-info-component-phone-text text-gray-600 text-sm font-sans hover:text-primary transition-colors\">(555) 123-4567</a></div></div><!-- Hours --><div class=\"alloro-tpl-v1-release-section-location-info-component-hours flex items-start gap-4 py-5 border-t border-gray-100\"><div class=\"w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5 bg-primary-subtle\"><svg class=\"w-5 h-5 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg></div><div><h3 class=\"font-serif font-medium text-gray-900 text-lg mb-1\">Office Hours</h3><!-- AI-CONTENT: location-hours | Replace with actual office hours. --><div class=\"alloro-tpl-v1-release-section-location-info-component-hours-text text-gray-600 text-sm leading-relaxed font-sans\"><p>Monday - Friday: 8:00 AM - 5:00 PM</p><p>Saturday: 9:00 AM - 1:00 PM</p><p>Sunday: Closed</p></div></div></div><!-- Email --><div class=\"alloro-tpl-v1-release-section-location-info-component-email flex items-start gap-4 py-5 border-t border-b border-gray-100\"><div class=\"w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5 bg-primary-subtle\"><svg class=\"w-5 h-5 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"></path><polyline points=\"22,6 12,13 2,6\"></polyline></svg></div><div><h3 class=\"font-serif font-medium text-gray-900 text-lg mb-1\">Email</h3><!-- AI-CONTENT: location-email | Replace with office email. --><a href=\"mailto:info@example.com\" class=\"alloro-tpl-v1-release-section-location-info-component-email-text text-gray-600 text-sm font-sans hover:text-primary transition-colors\">info@example.com</a></div></div></div></div><div class=\"sticky top-24\"><!-- AI-IMAGE: location-map | Replace with embedded map or static map image for this location. --><div class=\"alloro-tpl-v1-release-section-location-info-component-map rounded-3xl overflow-hidden shadow-lg border border-gray-100 h-[500px] bg-[#f0f0f0]\"><div class=\"w-full h-full flex items-center justify-center text-gray-400 font-sans text-sm\">Map placeholder - Replace with Leaflet map or static image</div></div></div></div></section>"

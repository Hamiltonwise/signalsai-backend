[
  {
    "name": "section-hero",
    "content": "<!-- AI-IMAGE: first-visit-hero-bg | First visit hero. Warm new-patient welcoming imagery.\n       SEARCH KEYWORDS: new patient welcome, friendly dental reception, first dental visit, greeting patient.\n       REQUIREMENTS: Landscape, minimum 1920x800, professional quality.\n       FALLBACK: Any welcoming reception photo.\n       INSTRUCTION: Replace ONLY the url() value inside the section's background-image style; keep the linear-gradient overlay intact. Do not render this as an <img> element. -->\n<section class=\"alloro-tpl-v1-release-section-hero relative w-full min-h-[560px] md:min-h-[680px] flex items-center justify-center overflow-hidden py-20 md:py-24 bg-center bg-cover bg-no-repeat text-ivory\" style=\"background-image:linear-gradient(to bottom, rgba(15,23,42,0.75), rgba(15,23,42,0.55), rgba(15,23,42,0.85)), url('https://picsum.photos/1920/1080?random=150');\">\n  <div class=\"max-w-4xl mx-auto text-center\">\n\n    <div class=\"flex items-center justify-center gap-2 mb-6\">\n      <span class=\"alloro-tpl-v1-release-section-hero-component-eyebrow text-xs font-medium tracking-[0.18em] uppercase font-sans text-white/80\">Your First Visit</span>\n    </div>\n\n    <h1 class=\"alloro-tpl-v1-release-section-hero-component-title text-white font-semibold leading-tight mb-6 font-serif text-4xl md:text-5xl lg:text-6xl\">\n      What to Expect at Your <span class=\"text-primary\">First Dental Visit</span>\n    </h1>\n\n    <p class=\"alloro-tpl-v1-release-section-hero-component-subtitle text-lg md:text-xl leading-relaxed mb-10 max-w-2xl mx-auto font-sans text-white/80\">\n      We believe your first visit should be welcoming, informative, and completely stress-free. Our team is here to listen, answer your questions, and create a personalized plan for your dental health.\n    </p>\n\n    <div class=\"flex flex-wrap items-center justify-center gap-4 mb-10\">\n      <span class=\"alloro-tpl-v1-release-section-hero-component-badge-1 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm text-white/95 font-sans bg-white/60 border border-white/80\">\n        <svg class=\"w-4 h-4 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"/></svg>\n        Warm Welcome\n      </span>\n      <span class=\"alloro-tpl-v1-release-section-hero-component-badge-2 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm text-white/95 font-sans bg-white/60 border border-white/80\">\n        <svg class=\"w-4 h-4 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"/></svg>\n        Thorough Exam\n      </span>\n      <span class=\"alloro-tpl-v1-release-section-hero-component-badge-3 inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm text-white/95 font-sans bg-white/60 border border-white/80\">\n        <svg class=\"w-4 h-4 flex-shrink-0\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"/></svg>\n        Clear Answers\n      </span>\n    </div>\n\n    <div class=\"flex items-center justify-center\">\n\n      <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n\n      <a href=\"/consultation\" class=\"alloro-tpl-v1-release-section-hero-component-cta-button inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-full font-medium text-base transition-colors hover:opacity-90 font-sans\">\n        Request a Consultation\n        <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"/></svg>\n      </a>\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-intro",
    "content": "<section class=\"alloro-tpl-v1-release-section-intro bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-4xl mx-auto\">\n\n    <div class=\"flex items-center gap-2 mb-6\">\n      <span class=\"alloro-tpl-v1-release-section-intro-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Welcome to Our Practice</span>\n    </div>\n\n    <h2 class=\"alloro-tpl-v1-release-section-intro-component-title text-gray-900 mb-6 font-serif font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl\">\n      A Dental Visit Designed Around <span class=\"text-primary\">You</span>\n    </h2>\n\n    <p class=\"alloro-tpl-v1-release-section-intro-component-description text-gray-700 text-lg md:text-xl font-medium leading-relaxed mb-6 font-sans\">\n      Your first appointment is about more than just a dental exam. It is an opportunity for us to get to know you, understand your dental history, and learn about any concerns or goals you may have. We take the time to listen because every patient deserves a care plan that reflects their individual needs.\n    </p>\n\n    <p class=\"alloro-tpl-v1-release-section-intro-component-description-2 text-gray-600 text-base leading-relaxed mb-10 font-sans\">\n      Whether you are visiting for a routine cleaning, a specific concern, or a second opinion, our team will walk you through every step of the process. We believe that informed patients make confident decisions, and we are committed to providing the clarity and comfort you need to feel great about your dental care.\n    </p>\n\n    <div class=\"alloro-tpl-v1-release-section-intro-component-highlight-box bg-gray-100 rounded-3xl p-8 flex items-start gap-4\">\n      <div class=\"flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center bg-primary\">\n        <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z\"/></svg>\n      </div>\n      <div>\n        <h3 class=\"alloro-tpl-v1-release-section-intro-component-highlight-title text-gray-900 font-semibold text-base font-sans mb-2\">Our Promise to You</h3>\n        <p class=\"alloro-tpl-v1-release-section-intro-component-highlight-description text-gray-600 text-sm leading-relaxed font-sans\">We will never rush your visit, recommend unnecessary treatment, or leave your questions unanswered. Your comfort and trust are the foundation of everything we do.</p>\n      </div>\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-visit-steps",
    "content": "<section class=\"alloro-tpl-v1-release-section-visit-steps py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-[#f5f5f4]\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <div class=\"max-w-3xl mx-auto text-center mb-14 md:mb-20\">\n      <div class=\"flex items-center justify-center gap-2 mb-6\">\n        <span class=\"alloro-tpl-v1-release-section-visit-steps-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">What to Expect</span>\n      </div>\n      <h2 class=\"alloro-tpl-v1-release-section-visit-steps-component-title text-gray-900 font-semibold leading-tight mb-5 font-serif text-3xl md:text-4xl lg:text-5xl\">\n        Your First Visit, <span class=\"text-primary\">Step by Step</span>\n      </h2>\n      <p class=\"alloro-tpl-v1-release-section-visit-steps-component-subtitle text-gray-600 text-lg leading-relaxed max-w-2xl mx-auto font-sans\">\n        We have designed every part of your first appointment to be clear, comfortable, and reassuring so you know exactly what is happening and why.\n      </p>\n    </div>\n\n    <div class=\"max-w-4xl mx-auto flex flex-col gap-8 md:gap-10\">\n\n      <div class=\"alloro-tpl-v1-release-section-visit-steps-component-card-1 bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden\">\n        <div class=\"grid grid-cols-1 md:grid-cols-[auto_1fr]\">\n          <div class=\"bg-primary flex items-center justify-center px-8 py-8 md:py-0 md:min-h-full min-w-[5rem]\">\n            <span class=\"alloro-tpl-v1-release-section-visit-steps-component-step-number-1 text-white font-serif text-5xl font-semibold leading-none\">1</span>\n          </div>\n          <div class=\"p-8 md:p-10\">\n            <div class=\"flex items-center gap-3 mb-3\">\n              <div class=\"flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center bg-black/[0.05]\">\n                <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\"/></svg>\n              </div>\n              <h3 class=\"alloro-tpl-v1-release-section-visit-steps-component-step-title-1 text-gray-900 font-semibold font-serif text-xl\">Check-In and Welcome</h3>\n            </div>\n            <div class=\"inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium font-sans mb-4 bg-gray-100 text-gray-600\">About 10-15 minutes</div>\n            <p class=\"alloro-tpl-v1-release-section-visit-steps-component-card-description-1 text-gray-600 text-base leading-relaxed font-sans mb-3\">\n              Our front desk team will greet you and help with any remaining paperwork. To save time, we encourage you to complete your new patient forms online before your visit. Please bring your dental insurance card, a valid photo ID, and a list of any current medications.\n            </p>\n            <p class=\"text-gray-600 text-base leading-relaxed font-sans\">\n              We will verify your insurance benefits and answer any questions about coverage before your appointment begins, so there are no surprises.\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-visit-steps-component-card-2 bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden\">\n        <div class=\"grid grid-cols-1 md:grid-cols-[auto_1fr]\">\n          <div class=\"bg-primary flex items-center justify-center px-8 py-8 md:py-0 md:min-h-full min-w-[5rem]\">\n            <span class=\"alloro-tpl-v1-release-section-visit-steps-component-step-number-2 text-white font-serif text-5xl font-semibold leading-none\">2</span>\n          </div>\n          <div class=\"p-8 md:p-10\">\n            <div class=\"flex items-center gap-3 mb-3\">\n              <div class=\"flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center bg-black/[0.05]\">\n                <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01\"/></svg>\n              </div>\n              <h3 class=\"alloro-tpl-v1-release-section-visit-steps-component-step-title-2 text-gray-900 font-semibold font-serif text-xl\">Medical History Review</h3>\n            </div>\n            <div class=\"inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium font-sans mb-4 bg-gray-100 text-gray-600\">About 5-10 minutes</div>\n            <p class=\"alloro-tpl-v1-release-section-visit-steps-component-card-description-2 text-gray-600 text-base leading-relaxed font-sans mb-3\">\n              Your dentist will review your complete health history, including any medications, allergies, or medical conditions that may affect your dental care. This conversation helps us understand your overall health so we can provide the safest, most effective treatment.\n            </p>\n            <p class=\"text-gray-600 text-base leading-relaxed font-sans\">\n              We encourage you to share any concerns, past dental experiences, or questions at this stage. Open communication is the foundation of a great patient-provider relationship.\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-visit-steps-component-card-3 bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden\">\n        <div class=\"grid grid-cols-1 md:grid-cols-[auto_1fr]\">\n          <div class=\"bg-primary flex items-center justify-center px-8 py-8 md:py-0 md:min-h-full min-w-[5rem]\">\n            <span class=\"alloro-tpl-v1-release-section-visit-steps-component-step-number-3 text-white font-serif text-5xl font-semibold leading-none\">3</span>\n          </div>\n          <div class=\"p-8 md:p-10\">\n            <div class=\"flex items-center gap-3 mb-3\">\n              <div class=\"flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center bg-black/[0.05]\">\n                <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\"/></svg>\n              </div>\n              <h3 class=\"alloro-tpl-v1-release-section-visit-steps-component-step-title-3 text-gray-900 font-semibold font-serif text-xl\">Comprehensive Examination</h3>\n            </div>\n            <div class=\"inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium font-sans mb-4 bg-gray-100 text-gray-600\">About 20-30 minutes</div>\n            <p class=\"alloro-tpl-v1-release-section-visit-steps-component-card-description-3 text-gray-600 text-base leading-relaxed font-sans mb-3\">\n              Your dentist will perform a thorough oral examination, checking your teeth, gums, bite alignment, and soft tissues. Digital X-rays may be taken to identify issues not visible to the eye, such as cavities between teeth, bone loss, or impacted teeth.\n            </p>\n            <p class=\"text-gray-600 text-base leading-relaxed font-sans\">\n              We also perform an oral cancer screening and evaluate your jaw joint function as part of every new patient exam. Our goal is to catch potential problems early, when treatment is simplest and most effective.\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-visit-steps-component-card-4 bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden\">\n        <div class=\"grid grid-cols-1 md:grid-cols-[auto_1fr]\">\n          <div class=\"bg-primary flex items-center justify-center px-8 py-8 md:py-0 md:min-h-full min-w-[5rem]\">\n            <span class=\"alloro-tpl-v1-release-section-visit-steps-component-step-number-4 text-white font-serif text-5xl font-semibold leading-none\">4</span>\n          </div>\n          <div class=\"p-8 md:p-10\">\n            <div class=\"flex items-center gap-3 mb-3\">\n              <div class=\"flex-shrink-0 w-9 h-9 rounded-full flex items-center justify-center bg-black/[0.05]\">\n                <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\"/></svg>\n              </div>\n              <h3 class=\"alloro-tpl-v1-release-section-visit-steps-component-step-title-4 text-gray-900 font-semibold font-serif text-xl\">Discussion and Treatment Plan</h3>\n            </div>\n            <div class=\"inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-medium font-sans mb-4 bg-gray-100 text-gray-600\">About 10-15 minutes</div>\n            <p class=\"alloro-tpl-v1-release-section-visit-steps-component-card-description-4 text-gray-600 text-base leading-relaxed font-sans mb-3\">\n              After your exam, your dentist will sit down with you to review the findings in detail. We use digital images and X-rays to help you see exactly what we see, making it easy to understand your current dental health and any areas that need attention.\n            </p>\n            <p class=\"text-gray-600 text-base leading-relaxed font-sans\">\n              Together, we will create a personalized treatment plan that addresses your priorities, fits your schedule, and respects your budget. We will outline recommended next steps, answer every question, and schedule any follow-up appointments before you leave.\n            </p>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>"
  },
  {
    "name": "section-what-to-bring",
    "content": "<section class=\"alloro-tpl-v1-release-section-what-to-bring py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-gray-100\">\n  <div class=\"max-w-4xl mx-auto\">\n\n    <div class=\"flex items-center gap-2 mb-6\">\n      <span class=\"alloro-tpl-v1-release-section-what-to-bring-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Prepare for Your Visit</span>\n    </div>\n\n    <h2 class=\"alloro-tpl-v1-release-section-what-to-bring-component-title text-gray-900 mb-4 font-serif font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl\">\n      What to Bring to Your <span class=\"text-primary\">First Appointment</span>\n    </h2>\n\n    <p class=\"alloro-tpl-v1-release-section-what-to-bring-component-description text-gray-600 text-base md:text-lg leading-relaxed mb-12 max-w-2xl font-sans\">\n      Having the right documents ready helps us check you in quickly, understand your full health picture, and focus our time on delivering the care you need.\n    </p>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8\">\n\n      <div class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-1 bg-white rounded-3xl p-8 border border-gray-100 shadow-sm flex flex-col gap-5\">\n        <div class=\"flex items-start gap-4\">\n          <div class=\"flex-shrink-0 w-11 h-11 rounded-2xl flex items-center justify-center bg-gray-100\">\n            <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z\"/></svg>\n          </div>\n          <div>\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 bg-accent\">\n                <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n              </span>\n              <h3 class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-1-title text-gray-900 font-semibold text-base font-sans\">Insurance Information</h3>\n            </div>\n          </div>\n        </div>\n        <p class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-1-description text-gray-700 text-sm leading-relaxed font-sans\">\n          Bring your insurance card (front and back) along with your member and group number. If your coverage is through an employer, have that information handy as well. Our team will verify your benefits before your appointment begins.\n        </p>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-2 bg-white rounded-3xl p-8 border border-gray-100 shadow-sm flex flex-col gap-5\">\n        <div class=\"flex items-start gap-4\">\n          <div class=\"flex-shrink-0 w-11 h-11 rounded-2xl flex items-center justify-center bg-gray-100\">\n            <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2v-2M14 4h6m0 0v6m0-6L10 14\"/></svg>\n          </div>\n          <div>\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 bg-accent\">\n                <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n              </span>\n              <h3 class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-2-title text-gray-900 font-semibold text-base font-sans\">Photo ID</h3>\n            </div>\n          </div>\n        </div>\n        <p class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-2-description text-gray-700 text-sm leading-relaxed font-sans\">\n          Please bring a valid government-issued photo identification such as a driver's license or passport. This helps us verify your identity and keep your medical records secure.\n        </p>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-3 bg-white rounded-3xl p-8 border border-gray-100 shadow-sm flex flex-col gap-5\">\n        <div class=\"flex items-start gap-4\">\n          <div class=\"flex-shrink-0 w-11 h-11 rounded-2xl flex items-center justify-center bg-gray-100\">\n            <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01\"/></svg>\n          </div>\n          <div>\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 bg-accent\">\n                <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n              </span>\n              <h3 class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-3-title text-gray-900 font-semibold text-base font-sans\">Medical History</h3>\n            </div>\n          </div>\n        </div>\n        <p class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-3-description text-gray-700 text-sm leading-relaxed font-sans\">\n          Prepare a list of current medications, known allergies, and any medical conditions your dentist should be aware of. If you have recent lab results or medical clearances related to dental procedures, bring those along as well.\n        </p>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-4 bg-white rounded-3xl p-8 border border-gray-100 shadow-sm flex flex-col gap-5\">\n        <div class=\"flex items-start gap-4\">\n          <div class=\"flex-shrink-0 w-11 h-11 rounded-2xl flex items-center justify-center bg-gray-100\">\n            <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4\"/></svg>\n          </div>\n          <div>\n            <div class=\"flex items-center gap-2 mb-1\">\n              <span class=\"w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 bg-accent\">\n                <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n              </span>\n              <h3 class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-4-title text-gray-900 font-semibold text-base font-sans\">Referral and Records</h3>\n            </div>\n          </div>\n        </div>\n        <p class=\"alloro-tpl-v1-release-section-what-to-bring-component-card-4-description text-gray-700 text-sm leading-relaxed font-sans\">\n          If you were referred by another dentist, bring the referral letter along with any recent X-rays or imaging. Having your previous dental records available allows us to build on the work already done and avoid unnecessary duplicate testing.\n        </p>\n      </div>\n\n    </div>\n  </div>\n</section>"
  },
  {
    "name": "section-comfort-care",
    "content": "<section class=\"alloro-tpl-v1-release-section-comfort-care bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <div class=\"max-w-3xl mx-auto text-center mb-14 md:mb-20\">\n      <div class=\"flex items-center justify-center gap-2 mb-6\">\n        <span class=\"alloro-tpl-v1-release-section-comfort-care-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Comfort and Care</span>\n      </div>\n      <h2 class=\"alloro-tpl-v1-release-section-comfort-care-component-title text-gray-900 mb-5 font-serif font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl\">\n        Every Detail Designed for <span class=\"text-primary\">Your Comfort</span>\n      </h2>\n      <p class=\"alloro-tpl-v1-release-section-comfort-care-component-subtitle text-gray-600 text-lg leading-relaxed font-sans\">\n        Dental anxiety is common, and we take it seriously. From the moment you walk through our doors, every aspect of your experience is thoughtfully designed to help you feel safe, informed, and at ease.\n      </p>\n    </div>\n\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-start mb-16 md:mb-20\">\n\n      <div class=\"alloro-tpl-v1-release-section-comfort-care-component-environment-block rounded-3xl p-8 md:p-10 bg-gray-100\">\n        <div class=\"flex items-center gap-3 mb-5\">\n          <div class=\"flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center bg-gray-200\">\n            <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6\"/></svg>\n          </div>\n          <h3 class=\"alloro-tpl-v1-release-section-comfort-care-component-environment-title text-gray-900 font-serif text-xl font-semibold\">A Calming Office Environment</h3>\n        </div>\n        <p class=\"alloro-tpl-v1-release-section-comfort-care-component-environment-description text-gray-600 text-base leading-relaxed mb-4 font-sans\">\n          Our office is designed with your well-being in mind. From comfortable seating and a welcoming reception area to treatment rooms with a soothing atmosphere, we have created a space that puts patients at ease the moment they arrive.\n        </p>\n        <p class=\"text-gray-600 text-base leading-relaxed mb-6 font-sans\">\n          We understand that the sounds and sights of a dental office can be stressful for some patients. That is why we offer entertainment options and maintain a calm, unhurried pace throughout every visit.\n        </p>\n        <ul class=\"space-y-3\">\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-environment-item-1 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Comfortable seating and a relaxing reception area</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-environment-item-2 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Friendly, approachable staff at every step</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-environment-item-3 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Entertainment options during procedures</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-environment-item-4 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Modern, well-maintained treatment rooms</span>\n          </li>\n        </ul>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-comfort-care-component-pain-block rounded-3xl p-8 md:p-10 bg-gray-100\">\n        <div class=\"flex items-center gap-3 mb-5\">\n          <div class=\"flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center bg-gray-200\">\n            <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z\"/></svg>\n          </div>\n          <h3 class=\"alloro-tpl-v1-release-section-comfort-care-component-pain-title text-gray-900 font-serif text-xl font-semibold\">Pain Management and Comfort Options</h3>\n        </div>\n        <p class=\"alloro-tpl-v1-release-section-comfort-care-component-pain-description text-gray-600 text-base leading-relaxed mb-4 font-sans\">\n          We use the latest techniques and technology to make every procedure as comfortable as possible. Our team is trained in gentle injection methods, and we offer a range of anesthesia and sedation options tailored to your level of comfort.\n        </p>\n        <p class=\"text-gray-600 text-base leading-relaxed mb-6 font-sans\">\n          Communication is key during any procedure. We will always let you know what is happening, check in with you regularly, and stop immediately if you need a break. You are always in control.\n        </p>\n        <ul class=\"space-y-3\">\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-pain-item-1 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Local anesthesia with gentle technique</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-pain-item-2 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Sedation options available upon request</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-pain-item-3 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Ongoing communication throughout every procedure</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-comfort-care-component-pain-item-4 flex items-start gap-3\">\n            <span class=\"flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center mt-0.5 bg-gray-200\">\n              <svg class=\"w-3 h-3 text-accent\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-sm leading-relaxed font-sans\">Breaks offered whenever you need them</span>\n          </li>\n        </ul>\n      </div>\n\n    </div>\n\n    <div class=\"max-w-4xl mx-auto\">\n      <h3 class=\"text-gray-900 font-serif text-2xl font-semibold mb-8 text-center\">Frequently Asked Questions</h3>\n      <div class=\"flex flex-col gap-4\">\n\n        <div class=\"alloro-tpl-v1-release-section-comfort-care-component-faq-1 rounded-2xl border border-gray-200 bg-white\" data-faq-item=\"\">\n          <button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left\" data-faq-toggle=\"\">\n            <span class=\"text-gray-900 font-medium text-base font-sans\">What if I have dental anxiety?</span>\n            <span class=\"text-gray-400 text-xl flex-shrink-0 font-sans\" data-faq-icon=\"\">+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 grid-rows-[0fr] opacity-0\" data-faq-content=\"\">\n            <div class=\"overflow-hidden px-6 pb-5\">\n              <p class=\"text-gray-600 text-sm leading-relaxed font-sans\">Dental anxiety is more common than most people think, and our team is experienced in helping anxious patients feel comfortable. We offer a calm environment, patient-paced treatment, and sedation options when needed. Please let us know about your anxiety when you schedule your appointment so we can prepare accordingly.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"alloro-tpl-v1-release-section-comfort-care-component-faq-2 rounded-2xl border border-gray-200 bg-white\" data-faq-item=\"\">\n          <button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left\" data-faq-toggle=\"\">\n            <span class=\"text-gray-900 font-medium text-base font-sans\">Can I bring someone with me to my appointment?</span>\n            <span class=\"text-gray-400 text-xl flex-shrink-0 font-sans\" data-faq-icon=\"\">+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 grid-rows-[0fr] opacity-0\" data-faq-content=\"\">\n            <div class=\"overflow-hidden px-6 pb-5\">\n              <p class=\"text-gray-600 text-sm leading-relaxed font-sans\">Absolutely. You are welcome to bring a family member or friend for support. They can accompany you during the consultation portion of your visit. For certain procedures, we may ask them to wait in our comfortable reception area, but they will be nearby throughout your appointment.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"alloro-tpl-v1-release-section-comfort-care-component-faq-3 rounded-2xl border border-gray-200 bg-white\" data-faq-item=\"\">\n          <button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left\" data-faq-toggle=\"\">\n            <span class=\"text-gray-900 font-medium text-base font-sans\">What sedation options are available?</span>\n            <span class=\"text-gray-400 text-xl flex-shrink-0 font-sans\" data-faq-icon=\"\">+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 grid-rows-[0fr] opacity-0\" data-faq-content=\"\">\n            <div class=\"overflow-hidden px-6 pb-5\">\n              <p class=\"text-gray-600 text-sm leading-relaxed font-sans\">We offer several sedation options depending on your comfort level and the complexity of your procedure. These may include nitrous oxide (laughing gas), oral sedation, and in some cases IV sedation. Your dentist will discuss which options are appropriate for you during your initial consultation.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"alloro-tpl-v1-release-section-comfort-care-component-faq-4 rounded-2xl border border-gray-200 bg-white\" data-faq-item=\"\">\n          <button class=\"w-full flex items-center justify-between gap-4 px-6 py-5 text-left\" data-faq-toggle=\"\">\n            <span class=\"text-gray-900 font-medium text-base font-sans\">How do you handle patients with special needs?</span>\n            <span class=\"text-gray-400 text-xl flex-shrink-0 font-sans\" data-faq-icon=\"\">+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 grid-rows-[0fr] opacity-0\" data-faq-content=\"\">\n            <div class=\"overflow-hidden px-6 pb-5\">\n              <p class=\"text-gray-600 text-sm leading-relaxed font-sans\">Our practice is committed to providing compassionate, accessible care for patients with special needs. We accommodate physical, cognitive, and sensory considerations and are happy to adjust our approach to meet your individual requirements. Please contact us before your visit so we can ensure everything is prepared for your comfort.</p>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-cta",
    "content": "<section class=\"alloro-tpl-v1-release-section-cta py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-gray-900\">\n  <div class=\"max-w-5xl mx-auto text-center\">\n\n    <div class=\"flex items-center justify-center gap-2 mb-6\">\n      <span class=\"alloro-tpl-v1-release-section-cta-component-eyebrow text-xs font-medium tracking-[0.18em] uppercase font-sans text-gray-300\">Take the First Step</span>\n    </div>\n\n    <h2 class=\"alloro-tpl-v1-release-section-cta-component-title text-white font-serif font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl mb-5\">\n      Ready to Schedule Your <span class=\"text-accent\">First Visit</span>?\n    </h2>\n\n    <p class=\"alloro-tpl-v1-release-section-cta-component-description text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10 font-sans text-gray-200\">\n      We are welcoming new patients and would love to meet you. Scheduling is easy, and our team will guide you through every step from your very first call. Do not let uncertainty keep you from the care you deserve.\n    </p>\n\n    <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 mb-8\">\n\n      <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n\n      <a href=\"/consultation\" class=\"alloro-tpl-v1-release-section-cta-component-cta-button inline-flex items-center gap-2 bg-accent text-white px-8 py-4 rounded-full font-medium text-base transition-colors hover:opacity-90 font-sans\">\n        <svg class=\"w-5 h-5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\"/></svg>\n        Request a Consultation\n      </a>\n    </div>\n\n    <p class=\"text-gray-400 text-sm font-sans\">\n      Or call us at <a href=\"tel:\" class=\"alloro-tpl-v1-release-section-cta-component-phone-link text-accent hover:underline font-medium\">(555) 123-4567</a>\n    </p>\n\n  </div>\n</section>"
  }
]
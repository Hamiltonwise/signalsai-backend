    "name": "section-about-practice",
    "content": "<section class=\"alloro-tpl-v1-release-section-about-practice py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-gray-50\">\n  <div class=\"max-w-7xl mx-auto\">\n    <div class=\"flex flex-col items-center mb-16 md:mb-20 text-center\">\n      <div class=\"max-w-2xl mx-auto\">\n        <div class=\"flex items-center justify-center gap-2 mb-6\">\n          <!-- AI-CONTENT: about-practice-eyebrow | Replace with \"ABOUT [PRACTICE NAME]\". Use the business name. -->\n          <span class=\"alloro-tpl-v1-release-section-about-practice-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">ABOUT OUR PRACTICE</span>\n        </div>\n        <!-- AI-CONTENT: about-practice-heading | Replace with a warm, welcoming heading about the practice.\n             Use <span class=\"text-primary\"> for accent color on key phrase.\n             Example: \"Your comfort. Your health. <span class='text-primary'>Our priority.</span>\" -->\n        <h2 class=\"alloro-tpl-v1-release-section-about-practice-component-heading font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-medium tracking-tight leading-tight mb-6\">\n          Your comfort. Your health.<br><span class=\"text-primary\">Our priority.</span>\n        </h2>\n        <!-- AI-CONTENT: about-practice-para-1 | Replace with the practice's founding story or mission.\n             1-2 sentences about what makes the practice special. -->\n        <p class=\"alloro-tpl-v1-release-section-about-practice-component-subtext-1 text-gray-700 text-lg leading-relaxed font-sans mb-5\">\n          Our practice was founded on a simple belief: every patient deserves dental care that is gentle, thorough, and transparent. From routine checkups to advanced procedures, we take the time to listen, explain, and deliver results you can feel good about.\n        </p>\n        <!-- AI-CONTENT: about-practice-para-2 | Replace with info about the team, technology, or patient-centered approach.\n             1-2 sentences about qualifications and modern care. -->\n        <p class=\"alloro-tpl-v1-release-section-about-practice-component-subtext-2 text-gray-700 text-lg leading-relaxed font-sans mb-8\">\n          Our team combines years of clinical experience with the latest dental technology to provide care that is both effective and comfortable. We treat every patient like family and believe that a positive experience starts the moment you walk through our doors.\n        </p>\n        <div class=\"flex flex-col sm:flex-row gap-4 justify-center\">\n          <!-- AI-CONTENT: about-practice-cta-primary | Replace href and text if needed. -->\n\n          <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n\n          <a href=\"/consultation\" class=\"alloro-tpl-v1-release-section-about-practice-component-cta-primary inline-flex items-center justify-center gap-2 bg-primary text-white px-8 py-4 rounded-full font-medium text-base transition-opacity hover:opacity-90 font-sans\">\n            Request a Consultation\n          </a>\n          <!-- AI-CONTENT: about-practice-cta-secondary | Replace href and text if needed. -->\n          <a href=\"/about\" class=\"alloro-tpl-v1-release-section-about-practice-component-cta-secondary inline-flex items-center justify-center gap-2 border border-gray-200 text-gray-700 px-8 py-4 rounded-full font-medium text-base transition-colors hover:border-primary hover:text-primary font-sans\">\n            Meet Our Team\n          </a>\n        </div>\n      </div>\n    </div>\n    <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5\">\n      <!-- AI-CONTENT: about-practice-stat-1-number | Replace with the practice's years of experience. Example: \"15+\" -->\n      <!-- AI-CONTENT: about-practice-stat-1-label | Replace with a short label. Example: \"Years of experience\" -->\n      <div class=\"alloro-tpl-v1-release-section-about-practice-component-stat-1 rounded-3xl p-7 border border-gray-200 flex flex-col gap-3 bg-white\">\n        <div class=\"w-11 h-11 rounded-2xl flex items-center justify-center flex-shrink-0 bg-gray-100\">\n          <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg>\n        </div>\n        <h4 class=\"alloro-tpl-v1-release-section-about-practice-component-stat-1-number font-serif font-semibold text-gray-900 text-lg\">15+</h4>\n        <p class=\"alloro-tpl-v1-release-section-about-practice-component-stat-1-label text-gray-600 text-sm leading-relaxed font-sans\">Years of experience providing quality dental care to our community.</p>\n      </div>\n      <!-- AI-CONTENT: about-practice-stat-2-number | Replace with patient count. Example: \"10,000+\" -->\n      <!-- AI-CONTENT: about-practice-stat-2-label | Replace with a short label. Example: \"Patients served\" -->\n      <div class=\"alloro-tpl-v1-release-section-about-practice-component-stat-2 rounded-3xl p-7 border border-gray-200 flex flex-col gap-3 bg-white\">\n        <div class=\"w-11 h-11 rounded-2xl flex items-center justify-center flex-shrink-0 bg-gray-100\">\n          <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z\"></path></svg>\n        </div>\n        <h4 class=\"alloro-tpl-v1-release-section-about-practice-component-stat-2-number font-serif font-semibold text-gray-900 text-lg\">10,000+</h4>\n        <p class=\"alloro-tpl-v1-release-section-about-practice-component-stat-2-label text-gray-600 text-sm leading-relaxed font-sans\">Patients who trust us with their dental health and their families.</p>\n      </div>\n      <!-- AI-CONTENT: about-practice-stat-3-number | Replace with review count. Example: \"500+\" -->\n      <!-- AI-CONTENT: about-practice-stat-3-label | Replace with a short label. Example: \"5-star reviews\" -->\n      <div class=\"alloro-tpl-v1-release-section-about-practice-component-stat-3 rounded-3xl p-7 border border-gray-200 flex flex-col gap-3 bg-white\">\n        <div class=\"w-11 h-11 rounded-2xl flex items-center justify-center flex-shrink-0 bg-gray-100\">\n          <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z\"></path></svg>\n        </div>\n        <h4 class=\"alloro-tpl-v1-release-section-about-practice-component-stat-3-number font-serif font-semibold text-gray-900 text-lg\">500+</h4>\n        <p class=\"alloro-tpl-v1-release-section-about-practice-component-stat-3-label text-gray-600 text-sm leading-relaxed font-sans\">Five-star reviews from patients who appreciate our approach to care.</p>\n      </div>\n      <!-- AI-CONTENT: about-practice-stat-4-number | Replace with services count. Example: \"20+\" -->\n      <!-- AI-CONTENT: about-practice-stat-4-label | Replace with a short label. Example: \"Services offered\" -->\n      <div class=\"alloro-tpl-v1-release-section-about-practice-component-stat-4 rounded-3xl p-7 border border-gray-200 flex flex-col gap-3 bg-white\">\n        <div class=\"w-11 h-11 rounded-2xl flex items-center justify-center flex-shrink-0 bg-gray-100\">\n          <svg class=\"w-5 h-5 text-primary\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M4.318 6.318a4.5 4.5 0 016.364 0L12 7.636l1.318-1.318a4.5 4.5 0 116.364 6.364L12 20.364l-7.682-7.682a4.5 4.5 0 010-6.364z\"></path></svg>\n        </div>\n        <h4 class=\"alloro-tpl-v1-release-section-about-practice-component-stat-4-number font-serif font-semibold text-gray-900 text-lg\">20+</h4>\n        <p class=\"alloro-tpl-v1-release-section-about-practice-component-stat-4-label text-gray-600 text-sm leading-relaxed font-sans\">Dental services from preventive care to advanced restorative treatments.</p>\n      </div>\n    </div>\n  </div>\n</section>"

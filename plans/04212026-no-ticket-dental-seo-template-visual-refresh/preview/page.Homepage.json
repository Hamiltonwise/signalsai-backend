  {
    "name": "section-faq",
    "content": "<section class=\"alloro-tpl-v1-release-section-faq bg-[#f0f0ed] py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start\">\n    <div class=\"hidden lg:block sticky top-24\">\n      <!-- AI-IMAGE: faq-side-image | Replace with a warm patient consultation or office photo.\n           SEARCH KEYWORDS: dental consultation, patient talking to dentist, dental office warm interior.\n           REQUIREMENTS: Portrait orientation (4:5 aspect ratio), minimum 600x800.\n           DEFAULT: Keep current picsum placeholder. -->\n      <div class=\"alloro-tpl-v1-release-section-faq-component-image-wrapper rounded-3xl overflow-hidden shadow-xl aspect-[4/5] relative group\">\n        <img class=\"alloro-tpl-v1-release-section-faq-component-image w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700\" src=\"https://picsum.photos/600/800?random=88\" alt=\"Patient Consultation\" />\n        <div class=\"absolute inset-0 bg-black/10\"></div>\n        <div class=\"absolute bottom-8 left-8 right-8 p-6 rounded-2xl shadow-lg bg-white/90 backdrop-blur-sm\">\n          <p class=\"text-primary font-bold uppercase tracking-wider text-xs mb-2\">Patient Care</p>\n          <p class=\"font-serif text-xl text-gray-900\">\"We take the time to answer every question, ensuring you feel confident in your care.\"</p>\n        </div>\n      </div>\n    </div>\n    <div class=\"w-full\">\n      <!-- AI-CONTENT: faq-heading | Replace with the business's FAQ section heading. -->\n      <h2 class=\"alloro-tpl-v1-release-section-faq-component-heading font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-gray-900 mb-8 md:mb-12\">\n        Frequently asked<br/>questions\n      </h2>\n      <div>\n        <!-- AI-CONTENT: faq-q-1 | Replace question text. -->\n        <!-- AI-CONTENT: faq-a-1 | Replace answer text. Include internal links where relevant. -->\n        <div class=\"border-b border-gray-200 py-6\" data-faq-item>\n          <button class=\"w-full flex justify-between items-center text-left focus:outline-none group\" data-faq-toggle>\n            <span class=\"alloro-tpl-v1-release-section-faq-component-q-1 text-gray-900 font-medium font-serif text-lg md:text-xl group-hover:text-primary transition-colors pr-4\">How often should I visit the dentist?</span>\n            <span class=\"text-2xl text-gray-400 font-light flex-shrink-0\" data-faq-icon>+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\" data-faq-content>\n            <div class=\"alloro-tpl-v1-release-section-faq-component-a-1 overflow-hidden text-gray-600 text-base font-sans leading-relaxed pr-8\">\n              We recommend visiting every six months for a routine checkup and cleaning. Regular visits help prevent issues before they start. Learn more about our <a href=\"/services\" class=\"text-primary font-medium hover:underline\">preventive services</a> to keep your smile healthy.\n            </div>\n          </div>\n        </div>\n        <!-- AI-CONTENT: faq-q-2 | Replace question text. -->\n        <!-- AI-CONTENT: faq-a-2 | Replace answer text. -->\n        <div class=\"border-b border-gray-200 py-6\" data-faq-item>\n          <button class=\"w-full flex justify-between items-center text-left focus:outline-none group\" data-faq-toggle>\n            <span class=\"alloro-tpl-v1-release-section-faq-component-q-2 text-gray-900 font-medium font-serif text-lg md:text-xl group-hover:text-primary transition-colors pr-4\">How do I book an appointment?</span>\n            <span class=\"text-2xl text-gray-400 font-light flex-shrink-0\" data-faq-icon>+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\" data-faq-content>\n            <div class=\"alloro-tpl-v1-release-section-faq-component-a-2 overflow-hidden text-gray-600 text-base font-sans leading-relaxed pr-8\">\n              Booking is easy. You can request an appointment online through our\n <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n <a href=\"/consultation\" class=\"text-primary font-medium hover:underline\">consultation page</a> or give us a call directly. Visit our <a href=\"/contact\" class=\"text-primary font-medium hover:underline\">contact page</a> for our phone number and office hours.\n            </div>\n          </div>\n        </div>\n        <!-- AI-CONTENT: faq-q-3 | Replace question text. -->\n        <!-- AI-CONTENT: faq-a-3 | Replace answer text. -->\n        <div class=\"border-b border-gray-200 py-6\" data-faq-item>\n          <button class=\"w-full flex justify-between items-center text-left focus:outline-none group\" data-faq-toggle>\n            <span class=\"alloro-tpl-v1-release-section-faq-component-q-3 text-gray-900 font-medium font-serif text-lg md:text-xl group-hover:text-primary transition-colors pr-4\">How do I know which treatment I need?</span>\n            <span class=\"text-2xl text-gray-400 font-light flex-shrink-0\" data-faq-icon>+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\" data-faq-content>\n            <div class=\"alloro-tpl-v1-release-section-faq-component-a-3 overflow-hidden text-gray-600 text-base font-sans leading-relaxed pr-8\">\n              Not sure what you need? No problem. Schedule a\n <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n <a href=\"/consultation\" class=\"text-primary font-medium hover:underline\">consultation</a> and our team will assess your oral health and create a personalized plan just for you.\n            </div>\n          </div>\n        </div>\n        <!-- AI-CONTENT: faq-q-4 | Replace question text. -->\n        <!-- AI-CONTENT: faq-a-4 | Replace answer text. -->\n        <div class=\"border-b border-gray-200 py-6\" data-faq-item>\n          <button class=\"w-full flex justify-between items-center text-left focus:outline-none group\" data-faq-toggle>\n            <span class=\"alloro-tpl-v1-release-section-faq-component-q-4 text-gray-900 font-medium font-serif text-lg md:text-xl group-hover:text-primary transition-colors pr-4\">What should I do in a dental emergency?</span>\n            <span class=\"text-2xl text-gray-400 font-light flex-shrink-0\" data-faq-icon>+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\" data-faq-content>\n            <div class=\"alloro-tpl-v1-release-section-faq-component-a-4 overflow-hidden text-gray-600 text-base font-sans leading-relaxed pr-8\">\n              If you are in pain or have a dental emergency, please <a href=\"/contact\" class=\"text-primary font-medium hover:underline\">contact us immediately</a>. We offer same-day emergency appointments to get you out of pain fast.\n            </div>\n          </div>\n        </div>\n        <!-- AI-CONTENT: faq-q-5 | Replace question text. -->\n        <!-- AI-CONTENT: faq-a-5 | Replace answer text. -->\n        <div class=\"border-b border-gray-200 py-6\" data-faq-item>\n          <button class=\"w-full flex justify-between items-center text-left focus:outline-none group\" data-faq-toggle>\n            <span class=\"alloro-tpl-v1-release-section-faq-component-q-5 text-gray-900 font-medium font-serif text-lg md:text-xl group-hover:text-primary transition-colors pr-4\">Do dental treatments hurt?</span>\n            <span class=\"text-2xl text-gray-400 font-light flex-shrink-0\" data-faq-icon>+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\" data-faq-content>\n            <div class=\"alloro-tpl-v1-release-section-faq-component-a-5 overflow-hidden text-gray-600 text-base font-sans leading-relaxed pr-8\">\n              Your comfort is our top priority. We use modern technology and gentle techniques to ensure a pain-free experience. Learn more about our <a href=\"/about\" class=\"text-primary font-medium hover:underline\">compassionate approach</a> and sedation options.\n            </div>\n          </div>\n        </div>\n        <!-- AI-CONTENT: faq-q-6 | Replace question text. -->\n        <!-- AI-CONTENT: faq-a-6 | Replace answer text. -->\n        <div class=\"border-b border-gray-200 py-6\" data-faq-item>\n          <button class=\"w-full flex justify-between items-center text-left focus:outline-none group\" data-faq-toggle>\n            <span class=\"alloro-tpl-v1-release-section-faq-component-q-6 text-gray-900 font-medium font-serif text-lg md:text-xl group-hover:text-primary transition-colors pr-4\">Are dental X-rays safe?</span>\n            <span class=\"text-2xl text-gray-400 font-light flex-shrink-0\" data-faq-icon>+</span>\n          </button>\n          <div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\" data-faq-content>\n            <div class=\"alloro-tpl-v1-release-section-faq-component-a-6 overflow-hidden text-gray-600 text-base font-sans leading-relaxed pr-8\">\n              Yes, we use state-of-the-art digital X-rays which use significantly less radiation than traditional film. Learn more about our <a href=\"/services\" class=\"text-primary font-medium hover:underline\">modern technology</a> on our services page.\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>"
  },
  {
    "name": "section-insurance",
    "content": "<section class=\"alloro-tpl-v1-release-section-insurance bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20 text-center\">\n  <div class=\"max-w-4xl mx-auto\">\n    <!-- AI-CONTENT: insurance-heading | Replace with the business's insurance/payment heading. -->\n    <h2 class=\"alloro-tpl-v1-release-section-insurance-component-heading font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-gray-900 mb-6 md:mb-8\">\n      Insurance &amp; payment options\n    </h2>\n    <div class=\"text-gray-600 mb-8 md:mb-12 font-sans text-base md:text-lg leading-relaxed max-w-3xl mx-auto space-y-6\">\n      <!-- AI-CONTENT: insurance-body-1 | Replace with scraped insurance info paragraph 1. -->\n      <p class=\"alloro-tpl-v1-release-section-insurance-component-subtext-1\">We believe that quality dental care should be accessible to everyone. That is why we accept most major insurance plans and work closely with you to verify coverage and maximize your benefits.</p>\n      <!-- AI-CONTENT: insurance-body-2 | Replace with scraped insurance info paragraph 2. -->\n      <p class=\"alloro-tpl-v1-release-section-insurance-component-subtext-2\">For those without insurance or with out-of-pocket costs, we offer transparent pricing and flexible payment options, including CareCredit and in-house plans, so you can focus on your smile without financial stress.</p>\n    </div>\n    <div class=\"flex justify-center\">\n      <!-- AI-CONTENT: insurance-cta | Replace button text and href with the business's call-to-action. -->\n      <a href=\"/contact\" class=\"alloro-tpl-v1-release-section-insurance-component-cta-button inline-flex items-center justify-center px-8 py-3 rounded-full font-medium transition-all duration-200 text-base md:text-lg bg-primary text-white hover:opacity-90 w-full md:w-auto\">\n        Get insurance info\n      </a>\n    </div>\n  </div>\n</section>"
  },
  {
    "name": "section-gallery",
    "content": "<section class=\"alloro-tpl-v1-release-section-gallery bg-[#f9f9f9] py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n    <div class=\"flex flex-col md:flex-row justify-between items-end mb-10 md:mb-12\">\n      <div>\n        <!-- AI-CONTENT: gallery-heading | Replace with the business's gallery section heading. -->\n        <h2 class=\"alloro-tpl-v1-release-section-gallery-component-heading font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-gray-900 mb-4\">Our clinic gallery</h2>\n        <!-- AI-CONTENT: gallery-subtext | Replace with the business's gallery description. -->\n        <p class=\"alloro-tpl-v1-release-section-gallery-component-subtext text-gray-600 font-sans text-base md:text-lg max-w-md\">A glimpse into our modern, comfortable, and state-of-the-art facility designed with you in mind.</p>\n      </div>\n    </div>\n    <div class=\"alloro-tpl-v1-release-section-gallery-component-grid grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 transition-all duration-500\" data-gallery-grid>\n      <!-- AI-IMAGE: gallery-image-1 | Replace with the business's primary gallery photo (large feature image).\n           SEARCH KEYWORDS: dental office reception, clinic lobby, modern dental interior.\n           REQUIREMENTS: Square or landscape, minimum 800x800, high resolution.\n           DEFAULT: Keep current picsum placeholder. -->\n      <div class=\"relative group rounded-2xl md:rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 col-span-1 md:col-span-2 row-span-2 min-h-[120px] md:min-h-[150px]\">\n        <img class=\"alloro-tpl-v1-release-section-gallery-component-image-1 w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700\" src=\"https://picsum.photos/800/800?random=1\" alt=\"Dental Office Reception\" />\n        <div class=\"absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors duration-300 flex items-ce
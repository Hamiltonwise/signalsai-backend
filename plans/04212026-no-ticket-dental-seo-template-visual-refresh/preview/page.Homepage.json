  {
    "name": "section-meet-our-team",
    "content": "<!-- AI-INSTRUCTION: Team/specialists section on a white background with credential badges, a doctors post block, and a CTA. Uses solid brand buttons (not gradient) because the section background is white. Keep rectangular rounded-lg button shape. -->\n<section class=\"alloro-tpl-v1-release-section-team bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <!-- Section Header -->\n    <div class=\"alloro-tpl-v1-release-section-team-component-header text-center mb-6\">\n      <!-- AI-CONTENT: team-eyebrow | Short uppercase label above the heading. 2-4 words. -->\n      <span class=\"alloro-tpl-v1-release-section-team-component-eyebrow inline-block text-accent font-semibold uppercase tracking-widest text-sm mb-3\">Our Specialists</span>\n\n      <!-- AI-CONTENT: team-heading | Main heading for the team section. Should reference the specialty and commitment. -->\n      <h2 class=\"alloro-tpl-v1-release-section-team-component-heading text-3xl md:text-4xl lg:text-5xl font-serif text-gray-900 mb-4\">Board-Certified Endodontists Dedicated to Your Care</h2>\n\n      <!-- AI-CONTENT: team-subtext | 1-3 sentences introducing the team's training, certifications, and patient-care philosophy. -->\n      <p class=\"alloro-tpl-v1-release-section-team-component-subtext text-gray-700 text-lg max-w-2xl mx-auto\">Our team brings advanced specialty training, board certification, and a genuine commitment to patient comfort. Every provider at Coastal Endodontic Studio is focused on one goal: giving your tooth the best possible outcome.</p>\n    </div>\n\n    <!-- Credential Badges -->\n    <!-- AI-CONTENT: team-credentials | Replace with the business's actual credentials, certifications, and awards. Add or remove badge spans as needed — typically 3-7 items. Keep each label short (under ~60 characters). -->\n    <div class=\"alloro-tpl-v1-release-section-team-component-credentials flex flex-wrap justify-center gap-3 mb-14\">\n      <span class=\"alloro-tpl-v1-release-section-team-component-credential-badge bg-primary-subtle text-primary text-xs font-semibold px-4 py-2 rounded-full\">Diplomate, American Board of Endodontics</span>\n      <span class=\"alloro-tpl-v1-release-section-team-component-credential-badge bg-primary-subtle text-primary text-xs font-semibold px-4 py-2 rounded-full\">Board Certified Endodontists</span>\n      <span class=\"alloro-tpl-v1-release-section-team-component-credential-badge bg-primary-subtle text-primary text-xs font-semibold px-4 py-2 rounded-full\">Omicron Kappa Upsilon Honor Society</span>\n      <span class=\"alloro-tpl-v1-release-section-team-component-credential-badge bg-primary-subtle text-primary text-xs font-semibold px-4 py-2 rounded-full\">American Association of Endodontics</span>\n      <span class=\"alloro-tpl-v1-release-section-team-component-credential-badge bg-primary-subtle text-primary text-xs font-semibold px-4 py-2 rounded-full\">SF Dental Society Ethics &amp; Professionalism Award</span>\n    </div>\n\n    <!-- Doctors Grid Shortcode -->\n    <!-- AI-INSTRUCTION: This renders the doctors/providers post collection. Update the `id` to a unique block id for the page (kebab-case) and `items` to match the post collection slug (typically 'doctors' or 'providers'). Adjust `limit` based on team size. -->\n    {{ post_block id='doctors-grid' items='doctors' limit='10' }}\n\n    <!-- CTA -->\n    <div class=\"alloro-tpl-v1-release-section-team-component-cta mt-14 text-center\">\n      <!-- AI-CONTENT: team-cta-text | Closing copy that invites patients to take action. 1-2 sentences. Mention referrals/self-referrals if relevant to the practice. -->\n      <p class=\"alloro-tpl-v1-release-section-team-component-cta-text text-gray-700 text-base mb-6 max-w-xl mx-auto\">Ready to meet our team in person? We welcome referrals and self-referred patients across all four Central Coast locations. Call us or request a consultation online.</p>\n\n      <div class=\"alloro-tpl-v1-release-section-team-component-cta-actions flex flex-col sm:flex-row gap-4 justify-center\">\n        <!-- AI-CONTENT: team-cta-phone | Replace the tel: href with the business's phone number (digits only, with country code) and the display text with the formatted number. Keep both in sync. -->\n        <a href=\"tel:8059603636\" class=\"alloro-tpl-v1-release-section-team-component-cta-button-primary inline-block bg-primary text-white font-semibold px-8 py-4 rounded-full text-base hover:opacity-90 transition-opacity\">Call (805) 960-3636</a>\n\n        <!-- AI-CONTENT: team-cta-secondary | Replace the href with the business's contact or consultation page URL. Update button text if needed. -->\n        <a href=\"/contact\" class=\"alloro-tpl-v1-release-section-team-component-cta-button-secondary inline-block border-2 border-primary text-primary font-semibold px-8 py-4 rounded-full text-base hover:bg-primary-subtle transition-colors\">Schedule a Consultation</a>\n      </div>\n    </div>\n\n  </div>\n\n  <!-- ALLORO_SHORTCODE: doctors -->\n</section>"
  },

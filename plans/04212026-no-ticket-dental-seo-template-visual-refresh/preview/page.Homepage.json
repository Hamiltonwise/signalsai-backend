  {
    "name": "section-why-choose-us",
    "content": "<section class=\"alloro-tpl-v1-release-section-why-choose-us bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center\">\n    <div class=\"order-2 lg:order-1\">\n      <!-- AI-CONTENT: why-choose-heading | Replace with the business's \"why choose us\" heading. -->\n      <h2 class=\"alloro-tpl-v1-release-section-why-choose-us-component-heading font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-gray-900 mb-6\">\n        Why choose us?\n      </h2>\n      <!-- AI-CONTENT: why-choose-subtext | Replace with 1-2 sentences explaining the practice's approach.\n           Warm, inviting tone. Mention what sets the practice apart. -->\n      <p class=\"alloro-tpl-v1-release-section-why-choose-us-component-subtext text-gray-600 font-sans text-base md:text-lg leading-relaxed mb-8 md:mb-10\">\n        We believe that choosing a dentist is one of the most important health decisions you can make. Here is why patients choose us and keep coming back for their entire family's care.\n      </p>\n      <ul class=\"alloro-tpl-v1-release-section-why-choose-us-component-list space-y-6 mb-10\">\n        <!-- AI-CONTENT: why-choose-point-1 | Replace with the business's first differentiator. -->\n        <li class=\"flex items-start border-b border-gray-100 pb-6 text-gray-700 font-sans text-base md:text-lg\">\n          <span class=\"mr-4 text-primary\">&#9679;</span>\n          <span class=\"alloro-tpl-v1-release-section-why-choose-us-component-point-1\">Full-scope dental care: preventive, restorative, and cosmetic</span>\n        </li>\n        <!-- AI-CONTENT: why-choose-point-2 | Replace with the business's second differentiator. -->\n        <li class=\"flex items-start border-b border-gray-100 pb-6 text-gray-700 font-sans text-base md:text-lg\">\n          <span class=\"mr-4 text-primary\">&#9679;</span>\n          <span class=\"alloro-tpl-v1-release-section-why-choose-us-component-point-2\">Zero-judgment approach to treatment</span>\n        </li>\n        <!-- AI-CONTENT: why-choose-point-3 | Replace with the business's third differentiator. -->\n        <li class=\"flex items-start border-b border-gray-100 pb-6 text-gray-700 font-sans text-base md:text-lg\">\n          <span class=\"mr-4 text-primary\">&#9679;</span>\n          <span class=\"alloro-tpl-v1-release-section-why-choose-us-component-point-3\">Friendly, compassionate team that puts patients first</span>\n        </li>\n        <!-- AI-CONTENT: why-choose-point-4 | Replace with the business's fourth differentiator. -->\n        <li class=\"flex items-start border-b border-gray-100 pb-6 text-gray-700 font-sans text-base md:text-lg\">\n          <span class=\"mr-4 text-primary\">&#9679;</span>\n          <span class=\"alloro-tpl-v1-release-section-why-choose-us-component-point-4\">Online scheduling and flexible appointments</span>\n        </li>\n        <!-- AI-CONTENT: why-choose-point-5 | Replace with the business's fifth differentiator. -->\n        <li class=\"flex items-start pb-6 text-gray-700 font-sans text-base md:text-lg\">\n          <span class=\"mr-4 text-primary\">&#9679;</span>\n          <span class=\"alloro-tpl-v1-release-section-why-choose-us-component-point-5\">A modern office serving a growing, hardworking community</span>\n        </li>\n      </ul>\n      <!-- AI-CONTENT: why-choose-cta | Replace button text and href with the business's call-to-action. -->\n\n      <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n\n      <a href=\"/consultation\" class=\"alloro-tpl-v1-release-section-why-choose-us-component-cta-button inline-flex items-center justify-center px-8 py-4 rounded-full font-medium transition-all duration-200 text-base md:text-lg bg-primary text-white hover:opacity-90 w-full md:w-auto\">\n        Request free consultation\n      </a>\n    </div>\n    <div class=\"h-[300px] md:h-[400px] lg:h-[500px] bg-[#f0f0f0] rounded-3xl overflow-hidden flex items-center justify-center order-1 lg:order-2 w-full\">\n      <!-- AI-IMAGE: why-choose-image | Replace with a real photo of the office, team, or happy patient.\n           SEARCH KEYWORDS: happy dental patient, modern dental office, dental team group photo.\n           REQUIREMENTS: Landscape or square, minimum 800x600, professional quality, warm and inviting.\n           DEFAULT: Keep placeholder. -->\n      <img class=\"alloro-tpl-v1-release-section-why-choose-us-component-image w-full h-full object-cover\" src=\"https://picsum.photos/800/600?random=30\" alt=\"Why choose us\" />\n    </div>\n  </div>\n</section>"
  },
  {
    "name": "section-testimonials",
    "content": "<section class=\"alloro-tpl-v1-release-section-testimonials bg-[#f9f9f9] py-16 md:py-24 px-6 md:px-12 lg:px-20 overflow-hidden\">\n  <div class=\"max-w-7xl mx-auto\">\n    <div class=\"flex flex-col md:flex-row justify-between items-end mb-12 md:mb-16 px-2\">\n      <div>\n        <!-- AI-CONTENT: testimonials-heading | Replace with the business's testimonials section heading. -->\n        <h2 class=\"alloro-tpl-v1-release-section-testimonials-component-heading font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-gray-900 text-center md:text-left w-full md:w-auto mb-2 md:mb-0\">\n          What our patients are saying\n        </h2>\n        <!-- AI-CONTENT: testimonials-subtext | Replace with a short description about patient feedback. -->\n        <p class=\"alloro-tpl-v1-release-section-testimonials-component-subtext text-gray-600 font-sans text-base md:text-lg text-center md:text-left\">\n          Real reviews from real patients who trust us with their smiles. See what they have to say about their experience.\n        </p>\n      </div>\n      <a href=\"/reviews\" class=\"alloro-tpl-v1-release-section-testimonials-component-cta-desktop hidden md:inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-medium text-sm font-sans transition-opacity hover:opacity-90 flex-shrink-0\">\n        See More\n        <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"></path></svg>\n      </a>\n    </div>\n    {{ review_block id='review-carousel' location='primary' min_rating='4' limit='20' }}\n    <div class=\"flex justify-center mt-10 md:hidden\">\n      <a href=\"/reviews\" class=\"alloro-tpl-v1-release-section-testimonials-component-cta-mobile inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-medium text-sm font-sans transition-opacity hover:opacity-90\">\n        See More\n        <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"></path></svg>\n      </a>\n    </div>\n  </div>\n\n  <!-- ALLORO_SHORTCODE: reviews -->\n</section>"

  {
    "name": "section-hero",
    "content": "<!-- AI-IMAGE: insurance-hero-bg | Insurance page hero. Professional front-desk or billing setting.\n       SEARCH KEYWORDS: dental front desk, reception desk, billing and insurance, dental administration.\n       REQUIREMENTS: Landscape, minimum 1920x800, professional quality.\n       FALLBACK: Any front-desk or reception photo.\n       INSTRUCTION: Replace ONLY the url() value inside the section's background-image style; keep the linear-gradient overlay intact. Do not render this as an <img> element. -->\n<section class=\"alloro-tpl-v1-release-section-hero relative w-full min-h-[560px] md:min-h-[680px] flex items-center justify-center overflow-hidden py-20 md:py-24 bg-center bg-cover bg-no-repeat text-ivory\" style=\"background-image:linear-gradient(to bottom, rgba(15,23,42,0.75), rgba(15,23,42,0.55), rgba(15,23,42,0.85)), url('https://picsum.photos/1920/1080?random=170');\">\n  <div class=\"max-w-4xl mx-auto text-center\">\n\n    <div class=\"flex items-center justify-center gap-2 mb-6\">\n      <span class=\"alloro-tpl-v1-release-section-hero-component-eyebrow text-xs font-medium tracking-[0.18em] uppercase font-sans text-white/80\">Patient Information</span>\n    </div>\n\n    <h1 class=\"alloro-tpl-v1-release-section-hero-component-title font-serif text-4xl md:text-5xl lg:text-6xl text-white font-semibold leading-tight mb-6\">\n      Insurance and <span class=\"text-primary\">Financial Information</span>\n    </h1>\n\n    <p class=\"alloro-tpl-v1-release-section-hero-component-subtitle text-lg md:text-xl leading-relaxed mb-10 max-w-2xl mx-auto font-sans text-white/80\">\n      We believe quality dental care should be accessible to everyone. Our team works with most major insurance plans and offers flexible payment and financing options so you can focus on what matters most.\n    </p>\n\n    <div class=\"flex items-center justify-center\">\n\n      <!-- AI-CONTENT: cta-label | Choose label by business.category:\n       - Endodontist / Endodontics → \"Book Appointment\"\n       - Orthodontist / Orthodontics → \"Schedule a Consultation\"\n       - Default / other dental → \"Request a Consultation\"\n       Apply the same label consistently across header, body, and footer CTAs for this site. -->\n\n      <a href=\"/consultation\" class=\"alloro-tpl-v1-release-section-hero-component-cta-button inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-full font-medium text-base transition-colors hover:opacity-90 font-sans\">\n        Request a Consultation\n        <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"/></svg>\n      </a>\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-insurance-overview",
    "content": "<section class=\"alloro-tpl-v1-release-section-insurance-overview bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-start\">\n\n      <div class=\"max-w-2xl\">\n        <div class=\"flex items-center gap-2 mb-6\">\n          <span class=\"alloro-tpl-v1-release-section-insurance-overview-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Insurance Coverage</span>\n        </div>\n        <h2 class=\"alloro-tpl-v1-release-section-insurance-overview-component-title font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-semibold leading-tight mb-6\">\n          We Work With <span class=\"text-primary\">Your Insurance</span>\n        </h2>\n        <p class=\"alloro-tpl-v1-release-section-insurance-overview-component-description text-gray-600 text-lg leading-relaxed mb-6 font-sans\">\n          Our practice works with most major dental insurance providers to help you get the most from your benefits. We understand that navigating insurance coverage can be confusing, and our team is here to simplify the process for you.\n        </p>\n        <p class=\"alloro-tpl-v1-release-section-insurance-overview-component-description-2 text-gray-600 text-base leading-relaxed mb-8 font-sans\">\n          Before your appointment, we will verify your insurance benefits and provide a clear estimate of your coverage and any out-of-pocket costs. We handle all claim submissions on your behalf so you can focus on your dental health, not paperwork.\n        </p>\n        <ul class=\"space-y-4\">\n          <li class=\"alloro-tpl-v1-release-section-insurance-overview-component-list-item-1 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">Most major PPO plans accepted</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-insurance-overview-component-list-item-2 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">We verify your benefits before your visit</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-insurance-overview-component-list-item-3 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">We file claims on your behalf</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-insurance-overview-component-list-item-4 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">Clear explanation of coverage and out-of-pocket costs</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-insurance-overview-component-list-item-5 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">Assistance with pre-authorization when required</span>\n          </li>\n        </ul>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-insurance-overview-component-info-card rounded-3xl bg-gray-100 p-8 md:p-10\">\n        <div class=\"flex items-center gap-3 mb-4\">\n          <div class=\"w-10 h-10 rounded-full flex items-center justify-center bg-primary\">\n            <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z\"/></svg>\n          </div>\n          <h3 class=\"text-gray-900 font-serif text-xl font-semibold\">Not Sure If We Accept Your Plan?</h3>\n        </div>\n        <p class=\"text-gray-600 text-base leading-relaxed mb-4 font-sans\">\n          Our team is happy to check your coverage before your visit. Give us a call and we will verify your benefits, explain what is covered, and help you understand any estimated costs so there are no surprises.\n        </p>\n        <p class=\"text-gray-600 text-base leading-relaxed mb-6 font-sans\">\n          Even if your plan is not listed, out-of-network benefits may still apply. We will work with you to explore every option.\n        </p>\n        <a href=\"tel:\" class=\"inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-medium text-base transition-colors hover:opacity-90 font-sans\">\n          <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z\"/></svg>\n          Call Us Today\n        </a>\n      </div>\n\n    </div>\n  </div>\n</section>"
  },
  {
    "name": "section-insurance-plans",
    "content": "<section class=\"alloro-tpl-v1-release-section-insurance-plans py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-[#f5f5f4]\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <div class=\"max-w-3xl mx-auto text-center mb-12 md:mb-16\">\n      <div class=\"flex items-center justify-center gap-2 mb-6\">\n        <span class=\"alloro-tpl-v1-release-section-insurance-plans-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Accepted Insurance</span>\n      </div>\n      <h2 class=\"alloro-tpl-v1-release-section-insurance-plans-component-title font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-semibold leading-tight mb-5\">\n        Insurance Plans <span class=\"text-primary\">We Accept</span>\n      </h2>\n      <p class=\"alloro-tpl-v1-release-section-insurance-plans-component-subtitle text-gray-600 text-base md:text-lg leading-relaxed font-sans\">\n        We are in-network with many major dental insurance providers and will work with your plan to help maximize your benefits. If your plan is not listed, contact us to learn about your out-of-network options.\n      </p>\n    </div>\n\n    <div class=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 md:gap-6 mb-12 md:mb-16\">\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-1 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Delta Dental</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-2 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Cigna</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-3 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Aetna</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-4 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">MetLife</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-5 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">United Healthcare</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-6 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Guardian</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-7 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">BlueCross BlueShield</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-8 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Humana</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-9 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Principal</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-10 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Sun Life</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-11 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">Ameritas</span></div>\n      <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-card-12 bg-white rounded-2xl border border-gray-200 px-4 py-5 flex items-center justify-center text-center shadow-sm\"><span class=\"text-gray-800 font-medium text-sm leading-snug font-sans\">GEHA</span></div>\n    </div>\n\n    <div class=\"alloro-tpl-v1-release-section-insurance-plans-component-note text-center\">\n      <p class=\"text-gray-500 text-base font-sans\">Don't see your plan? <a href=\"/contact\" class=\"text-primary font-medium hover:underline\">Contact us</a> - we may still be able to help.</p>\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-financing-options",
    "content": "<section class=\"alloro-tpl-v1-release-section-financing-options bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-center\">\n\n      <div class=\"max-w-2xl\">\n        <div class=\"flex items-center gap-2 mb-6\">\n          <span class=\"alloro-tpl-v1-release-section-financing-options-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Flexible Financing</span>\n        </div>\n        <h2 class=\"alloro-tpl-v1-release-section-financing-options-component-title font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-semibold leading-tight mb-5\">\n          Affordable <span class=\"text-primary\">Payment Plans</span>\n        </h2>\n        <p class=\"alloro-tpl-v1-release-section-financing-options-component-description text-gray-600 text-base md:text-lg leading-relaxed mb-4 font-sans\">\n          We understand that dental care is an important investment in your health, and we never want cost to stand in the way of the treatment you need. That is why we offer flexible third-party financing options that let you spread the cost of care into manageable monthly payments.\n        </p>\n        <p class=\"text-gray-600 text-base leading-relaxed mb-8 font-sans\">\n          Whether your treatment is a routine procedure or something more involved, we will help you find a financing option that fits your budget so you can move forward with confidence.\n        </p>\n        <ul class=\"space-y-4\">\n          <li class=\"alloro-tpl-v1-release-section-financing-options-component-list-item-1 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">Low monthly payments available</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-financing-options-component-list-item-2 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">Quick and easy application process</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-financing-options-component-list-item-3 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">Multiple plan options to fit your budget</span>\n          </li>\n          <li class=\"alloro-tpl-v1-release-section-financing-options-component-list-item-4 flex items-start gap-3\">\n            <span class=\"mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-accent flex items-center justify-center\">\n              <svg class=\"w-3 h-3 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M5 13l4 4L19 7\"/></svg>\n            </span>\n            <span class=\"text-gray-700 text-base leading-relaxed font-sans\">No penalty for early payoff</span>\n          </li>\n        </ul>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-financing-options-component-financing-card rounded-3xl bg-gray-100 p-8 md:p-10\">\n        <div class=\"flex items-center gap-3 mb-4\">\n          <div class=\"w-10 h-10 rounded-full flex items-center justify-center bg-primary\">\n            <svg class=\"w-5 h-5 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\"/></svg>\n          </div>\n          <h3 class=\"text-gray-900 font-serif text-xl font-semibold\">Third-Party Financing</h3>\n        </div>\n        <p class=\"text-gray-600 text-base leading-relaxed mb-4 font-sans\">\n          We partner with trusted third-party financing providers like CareCredit and Lending Club to give you access to flexible payment plans. These programs offer low interest rates, promotional periods, and straightforward terms.\n        </p>\n        <p class=\"text-gray-600 text-base leading-relaxed mb-6 font-sans\">\n          Applying takes just a few minutes, and many patients receive an instant decision. Our front desk team can help you apply in the office or you can apply online at your convenience.\n        </p>\n        <a href=\"/contact\" class=\"inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full font-medium text-base transition-colors hover:opacity-90 font-sans\">\n          Learn More\n          <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"/></svg>\n        </a>\n      </div>\n\n    </div>\n  </div>\n</section>"
  },
  {
    "name": "section-payment-policies",
    "content": "<section class=\"alloro-tpl-v1-release-section-payment-policies py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-gray-100\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <div class=\"max-w-3xl mx-auto text-center mb-12 md:mb-16\">\n      <div class=\"flex items-center justify-center gap-2 mb-6\">\n        <span class=\"alloro-tpl-v1-release-section-payment-policies-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Financial Policies</span>\n      </div>\n      <h2 class=\"alloro-tpl-v1-release-section-payment-policies-component-title font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-semibold leading-tight mb-5\">\n        Our Payment <span class=\"text-primary\">Policies</span>\n      </h2>\n      <p class=\"alloro-tpl-v1-release-section-payment-policies-component-subtitle text-gray-600 text-lg md:text-xl leading-relaxed font-sans\">\n        We believe financial concerns should never stand between you and the care you need. Here is everything you need to know about how we handle payments, co-pays, and insurance claims.\n      </p>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16\">\n\n      <div class=\"alloro-tpl-v1-release-section-payment-policies-component-card-1 bg-white rounded-3xl p-8 shadow-sm border border-gray-100 flex flex-col gap-5\">\n        <div class=\"flex items-center justify-center w-12 h-12 rounded-2xl bg-gray-100\">\n          <svg class=\"w-6 h-6 text-accent\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.75\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z\"/></svg>\n        </div>\n        <div>\n          <h3 class=\"alloro-tpl-v1-release-section-payment-policies-component-card-1-title font-serif text-xl font-semibold text-gray-900 mb-3\">Payment Due at Time of Service</h3>\n          <p class=\"alloro-tpl-v1-release-section-payment-policies-component-card-1-description text-gray-600 text-base leading-relaxed font-sans mb-3\">\n            Co-pays and estimated patient portions are collected at the time of your visit. We accept cash, personal checks, and all major credit and debit cards including Visa, MasterCard, American Express, and Discover.\n          </p>\n          <p class=\"text-gray-600 text-base leading-relaxed font-sans\">\n            We also accept Health Savings Account (HSA) and Flexible Spending Account (FSA) cards. Our goal is to make the payment process as simple and convenient as possible.\n          </p>\n        </div>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-payment-policies-component-card-2 bg-white rounded-3xl p-8 shadow-sm border border-gray-100 flex flex-col gap-5\">\n        <div class=\"flex items-center justify-center w-12 h-12 rounded-2xl bg-gray-100\">\n          <svg class=\"w-6 h-6 text-accent\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.75\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\"/></svg>\n        </div>\n        <div>\n          <h3 class=\"alloro-tpl-v1-release-section-payment-policies-component-card-2-title font-serif text-xl font-semibold text-gray-900 mb-3\">Insurance Claims</h3>\n          <p class=\"alloro-tpl-v1-release-section-payment-policies-component-card-2-description text-gray-600 text-base leading-relaxed font-sans mb-3\">\n            We submit all insurance claims on your behalf. Please be aware that the estimated coverage we provide is based on the information available from your insurance company and is not a guarantee of payment.\n          </p>\n          <p class=\"text-gray-600 text-base leading-relaxed font-sans\">\n            If there is a difference between the estimated and actual coverage, the remaining balance will be the patient's responsibility. We will notify you promptly of any balance adjustments.\n          </p>\n        </div>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-payment-policies-component-card-3 bg-white rounded-3xl p-8 shadow-sm border border-gray-100 flex flex-col gap-5\">\n        <div class=\"flex items-center justify-center w-12 h-12 rounded-2xl bg-gray-100\">\n          <svg class=\"w-6 h-6 text-accent\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.75\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z\"/></svg>\n        </div>\n        <div>\n          <h3 class=\"alloro-tpl-v1-release-section-payment-policies-component-card-3-title font-serif text-xl font-semibold text-gray-900 mb-3\">Questions About Your Bill</h3>\n          <p class=\"alloro-tpl-v1-release-section-payment-policies-component-card-3-description text-gray-600 text-base leading-relaxed font-sans mb-3\">\n            If you have questions about a bill or need clarification on charges, our billing team is here to help. We are committed to transparency and will take the time to walk you through every line item.\n          </p>\n          <p class=\"text-gray-600 text-base leading-relaxed font-sans\">\n            For patients with outstanding balances, we are happy to discuss payment plan arrangements. Please contact our office to set up a schedule that works for your situation.\n          </p>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"alloro-tpl-v1-release-section-payment-policies-component-hardship-note rounded-2xl bg-white p-6 border border-gray-100 max-w-3xl mx-auto text-center\">\n      <div class=\"flex items-center justify-center gap-3 mb-3\">\n        <div class=\"w-8 h-8 rounded-full flex items-center justify-center bg-accent\">\n          <svg class=\"w-4 h-4 text-white\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z\"/></svg>\n        </div>\n        <h4 class=\"text-gray-900 font-semibold text-base font-sans\">Financial Hardship</h4>\n      </div>\n      <p class=\"text-gray-600 text-sm leading-relaxed font-sans\">We understand that financial circumstances vary. If cost is a concern, please speak with our team. We are committed to finding a solution that allows you to receive the care you need without unnecessary financial stress.</p>\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-locations",
    "content": "<section class=\"alloro-tpl-v1-release-section-locations bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <div class=\"max-w-3xl mx-auto text-center mb-12 md:mb-16\">\n      <div class=\"flex items-center justify-center gap-2 mb-6\">\n        <span class=\"alloro-tpl-v1-release-section-locations-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Our Offices</span>\n      </div>\n      <h2 class=\"alloro-tpl-v1-release-section-locations-component-title font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-semibold leading-tight mb-5\">\n        Find a Location <span class=\"text-primary\">Near You</span>\n      </h2>\n      <p class=\"alloro-tpl-v1-release-section-locations-component-subtitle text-gray-600 text-lg md:text-xl leading-relaxed font-sans\">Have a billing question? Call your nearest office directly. Our team is happy to help.</p>\n    </div>\n\n    {{ post_block id='location-footer-columns' items='locations' limit='10' }}\n\n  </div>\n</section>"
  }
]
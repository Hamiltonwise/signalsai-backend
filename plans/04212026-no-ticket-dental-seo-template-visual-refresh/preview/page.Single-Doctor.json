    "name": "section-doctor-credentials",
    "content": "<section class=\"alloro-tpl-v1-release-section-doctor-credentials py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-[#f9f9f9]\"><div class=\"max-w-7xl mx-auto\"><div class=\"text-center mb-12 md:mb-16\"><h2 class=\"alloro-tpl-v1-release-section-doctor-credentials-component-heading font-serif text-3xl md:text-4xl lg:text-5xl text-gray-900 font-medium tracking-tight\">Education and Credentials</h2></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8\"><!-- Card 1: Education --><div class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-1 bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-gray-100\"><div class=\"w-12 h-12 rounded-2xl flex items-center justify-center mb-6 bg-primary-subtle\"><svg class=\"w-6 h-6 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 10v6M2 10l10-5 10 5-10 5z\"></path><path d=\"M6 12v5c0 1.1.9 2 2 2h8a2 2 0 002-2v-5\"></path></svg></div><!-- AI-CONTENT: doctor-education | Replace with doctor's degrees and schools. --><h3 class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-1-title font-serif text-xl font-medium text-gray-900 mb-3\">Education</h3><p class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-1-text text-gray-600 text-sm leading-relaxed font-sans\">Doctor of Dental Surgery (DDS) from State University School of Dentistry. Advanced residency in general and cosmetic dentistry.</p></div><!-- Card 2: Certifications --><div class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-2 bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-gray-100\"><div class=\"w-12 h-12 rounded-2xl flex items-center justify-center mb-6 bg-primary-subtle\"><svg class=\"w-6 h-6 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"8\" r=\"7\"></circle><polyline points=\"8.21 13.89 7 23 12 20 17 23 15.79 13.88\"></polyline></svg></div><!-- AI-CONTENT: doctor-certifications | Replace with doctor's board certifications and licenses. --><h3 class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-2-title font-serif text-xl font-medium text-gray-900 mb-3\">Certifications</h3><p class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-2-text text-gray-600 text-sm leading-relaxed font-sans\">Board certified by the American Board of General Dentistry. Licensed to practice in the state.</p></div><!-- Card 3: Memberships --><div class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-3 bg-white p-8 md:p-10 rounded-3xl shadow-sm border border-gray-100\"><div class=\"w-12 h-12 rounded-2xl flex items-center justify-center mb-6 bg-primary-subtle\"><svg class=\"w-6 h-6 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div><!-- AI-CONTENT: doctor-memberships | Replace with doctor's professional memberships. --><h3 class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-3-title font-serif text-xl font-medium text-gray-900 mb-3\">Memberships</h3><p class=\"alloro-tpl-v1-release-section-doctor-credentials-component-card-3-text text-gray-600 text-sm leading-relaxed font-sans\">Active member of the American Dental Association, Academy of General Dentistry, and the local dental society.</p></div></div></div></section>"

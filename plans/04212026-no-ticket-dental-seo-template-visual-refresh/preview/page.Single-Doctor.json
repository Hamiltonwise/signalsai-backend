md:p-10 rounded-3xl shadow-2xl border border-gray-100 relative z-10\"><!-- AI-CONTENT: consultation-form-heading | Replace with form heading. --><h3 class=\"alloro-tpl-v1-release-section-consultation-component-form-heading font-serif text-2xl md:text-3xl font-medium mb-8 text-center text-white\">Request Your Consultation</h3><form class=\"space-y-5\" data-form-submit=\"\" data-form-name=\"Consultation Request\" data-project-id=\"{{form_project_id}}\"><div class=\"hidden\" aria-hidden=\"true\"><input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\"></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-5\"><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-name block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Full Name</label><input type=\"text\" name=\"Full Name\" data-label=\"Full Name\" required class=\"alloro-tpl-v1-release-section-consultation-component-form-input-name w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:bg-white focus:border-transparent transition-all outline-none font-sans\" placeholder=\"John Doe\" /></div><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-phone block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Phone Number</label><input type=\"tel\" name=\"Phone Number\" data-label=\"Phone Number\" required class=\"alloro-tpl-v1-release-section-consultation-component-form-input-phone w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:bg-white focus:border-transparent transition-all outline-none font-sans\" placeholder=\"(555) 123-4567\" /></div></div><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-email block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Email Address</label><input type=\"email\" name=\"Email Address\" data-label=\"Email 
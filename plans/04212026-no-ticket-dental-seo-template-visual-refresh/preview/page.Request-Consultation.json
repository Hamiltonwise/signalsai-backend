    "name": "section-consultation",
    "content": "<section class=\"alloro-tpl-v1-release-section-consultation bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\"><div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24\"><div class=\"flex flex-col justify-center\"><!-- AI-CONTENT: consultation-badge | Replace with urgency messaging. Default: \"Limited Availability\". --><span class=\"alloro-tpl-v1-release-section-consultation-component-badge text-primary px-4 py-1.5 rounded-full text-sm font-bold tracking-wide uppercase mb-8 inline-flex self-start items-center gap-2 font-sans bg-primary-subtle\"><svg class=\"w-4 h-4 fill-current\" viewBox=\"0 0 24 24\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"></polygon></svg>Limited Availability</span><!-- AI-CONTENT: consultation-heading | Replace with consultation offer heading. --><h2 class=\"alloro-tpl-v1-release-section-consultation-component-heading font-serif text-3xl md:text-4xl lg:text-5xl text-white mb-8 font-medium leading-[1.1]\">Request your <span class=\"text-primary\">Free Consultation</span> today.</h2><!-- AI-CONTENT: consultation-subtext | Replace with what the consultation includes. 2-3 sentences. --><p class=\"alloro-tpl-v1-release-section-consultation-component-subtext text-white/70 text-lg leading-relaxed mb-10 font-sans\">Take the first step toward the smile you deserve. Our complimentary consultation includes a full exam, advanced imaging, and a personalized treatment plan tailored to your goals and budget. No pressure, no obligation - just honest answers from a team that genuinely cares.</p><div class=\"space-y-6 mb-12\"><!-- AI-CONTENT: consultation-benefit-1 | Replace title and description. --><div class=\"alloro-tpl-v1-release-section-consultation-component-benefit-1 flex items-center gap-5\"><div class=\"w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0 bg-primary-subtle\"><svg class=\"w-6 h-6 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><div><h4 class=\"alloro-tpl-v1-release-section-consultation-component-benefit-1-title font-bold text-xl text-white font-serif\">Comprehensive Exam</h4><p class=\"alloro-tpl-v1-release-section-consultation-component-benefit-1-description text-gray-500 text-sm mt-1 font-sans\">Full oral health assessment by our experienced team.</p></div></div><!-- AI-CONTENT: consultation-benefit-2 | Replace title and description. --><div class=\"alloro-tpl-v1-release-section-consultation-component-benefit-2 flex items-center gap-5\"><div class=\"w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0 bg-primary-subtle\"><svg class=\"w-6 h-6 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"></path><path d=\"m9 11 3 3L22 4\"></path></svg></div><div><h4 class=\"alloro-tpl-v1-release-section-consultation-component-benefit-2-title font-bold text-xl text-white font-serif\">Digital Imaging</h4><p class=\"alloro-tpl-v1-release-section-consultation-component-benefit-2-description text-gray-500 text-sm mt-1 font-sans\">State-of-the-art digital imaging for precise diagnostics.</p></div></div><!-- AI-CONTENT: consultation-benefit-3 | Replace title and description. --><div class=\"alloro-tpl-v1-release-section-consultation-component-benefit-3 flex items-center gap-5\"><div class=\"w-12 h-12 rounded-2xl flex items-center justify-center flex-shrink-0 bg-primary-subtle\"><svg class=\"w-6 h-6 text-primary\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M8 2v4\"></path><path d=\"M16 2v4\"></path><rect width=\"18\" height=\"18\" x=\"3\" y=\"4\" rx=\"2\"></rect><path d=\"M3 10h18\"></path></svg></div><div><h4 class=\"alloro-tpl-v1-release-section-consultation-component-benefit-3-title font-bold text-xl text-white font-serif\">Custom Treatment Plan</h4><p class=\"alloro-tpl-v1-release-section-consultation-component-benefit-3-description text-gray-500 text-sm mt-1 font-sans\">A roadmap designed around your goals and timeline.</p></div></div></div><div class=\"alloro-tpl-v1-release-section-consultation-component-review-slider p-8 bg-gray-50 rounded-3xl border border-gray-100 relative transition-all duration-500\" data-review-slider><div class=\"min-h-[100px] flex items-center\"><p data-review-text class=\"alloro-tpl-v1-release-section-consultation-component-review-text text-white/70 text-lg mb-4 relative z-10 font-sans\">The consultation was zero pressure. They explained everything clearly and helped me understand my options. Best dental experience ever!</p></div><div class=\"flex items-center gap-3 mt-4\"><div data-review-image class=\"w-10 h-10 bg-gray-200 rounded-full overflow-hidden\"><img src=\"https://picsum.photos/100/100?random=60\" alt=\"Patient\" class=\"alloro-tpl-v1-release-section-consultation-component-review-avatar w-full h-full object-cover\" /></div><div><div data-review-author class=\"alloro-tpl-v1-release-section-consultation-component-review-author font-bold text-white text-sm font-sans\">Happy Patient</div><div data-review-type class=\"alloro-tpl-v1-release-section-consultation-component-review-type text-xs text-gray-400 uppercase tracking-wide font-sans\">Dental Patient</div></div></div><div class=\"flex gap-2 mt-6 justify-center\"><button class=\"w-4 h-2 rounded-full bg-primary transition-all\" data-review-dot=\"0\"></button><button class=\"w-2 h-2 rounded-full bg-gray-300 transition-all\" data-review-dot=\"1\"></button><button class=\"w-2 h-2 rounded-full bg-gray-300 transition-all\" data-review-dot=\"2\"></button></div></div></div><div class=\"relative\"><div class=\"bg-white p-6 md:p-10 rounded-3xl shadow-2xl border border-gray-100 relative z-10 shadow-2xl\"><h3 class=\"alloro-tpl-v1-release-section-consultation-component-form-heading font-serif text-2xl md:text-3xl font-medium mb-8 text-center text-white\">Enter your details</h3><form class=\"space-y-5\" data-form-submit=\"\" data-form-name=\"Consultation Request\" data-project-id=\"{{form_project_id}}\"><div class=\"hidden\" aria-hidden=\"true\"><input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\"></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-5\"><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-name block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Full Name</label><input type=\"text\" name=\"Full Name\" data-label=\"Full Name\" required class=\"alloro-tpl-v1-release-section-consultation-component-form-input-name w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:bg-white focus:border-transparent transition-all outline-none font-sans\" placeholder=\"John Doe\" /></div><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-phone block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Phone Number</label><input type=\"tel\" name=\"Phone Number\" data-label=\"Phone Number\" required class=\"alloro-tpl-v1-release-section-consultation-component-form-input-phone w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:bg-white focus:border-transparent transition-all outline-none font-sans\" placeholder=\"(555) 123-4567\" /></div></div><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-email block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Email Address</label><input type=\"email\" name=\"Email Address\" data-label=\"Email Address\" required class=\"alloro-tpl-v1-release-section-consultation-component-form-input-email w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:bg-white focus:border-transparent transition-all outline-none font-sans\" placeholder=\"john@example.com\" /></div><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-location block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Preferred Location</label><div class=\"relative\"><select name=\"Preferred Location\" data-label=\"Preferred Location\" class=\"alloro-tpl-v1-release-section-consultation-component-form-select-location w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:bg-white focus:border-transparent transition-all outline-none text-white/70 appearance-none cursor-pointer font-sans\"><option value=\"Main Office\">Main Office</option><option value=\"North Office\">North Office</option><option value=\"South Office\">South Office</option></select><div class=\"absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400\">&#9660;</div></div></div><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-notes block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Additional Notes</label><textarea rows=\"3\" name=\"Additional Notes\" data-label=\"Additional Notes\" class=\"alloro-tpl-v1-release-section-consultation-component-form-textarea-notes w-full p-4 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:bg-white focus:border-transparent transition-all outline-none resize-none font-sans\" placeholder=\"Tell us about your needs...\"></textarea></div><div><label class=\"alloro-tpl-v1-release-section-consultation-component-form-label-time block text-xs font-bold text-white/80 uppercase tracking-wider mb-2 ml-1 font-sans\">Preferred Time</label><input type=\"hidden\" name=\"Preferred Time\" data-label=\"Preferred Time\" id=\"time-value\" value=\"\" /><div class=\"grid grid-cols-3 gap-3\"><button type=\"button\" data-time-btn=\"Morning\" class=\"alloro-tpl-v1-release-section-consultation-component-form-time-btn-morning py-3 px-4 rounded-xl border border-gray-200 bg-gray-50 text-white/80 text-sm font-medium font-sans transition-all hover:border-gray-400\" onclick=\"selectTime(this)\">Morning</button><button type=\"button\" data-time-btn=\"Afternoon\" class=\"alloro-tpl-v1-release-section-consultation-component-form-time-btn-afternoon py-3 px-4 rounded-xl border border-gray-200 bg-gray-50 text-white/80 text-sm font-medium font-sans transition-all hover:border-gray-400\" onclick=\"selectTime(this)\">Afternoon</button><button type=\"button\" data-time-btn=\"Evening\" class=\"alloro-tpl-v1-release-section-consultation-component-form-time-btn-evening py-3 px-4 rounded-xl border border-gray-200 bg-gray-50 text-white/80 text-sm font-medium font-sans transition-all hover:border-gray-400\" onclick=\"selectTime(this)\">Evening</button></div></div><button type=\"submit\" class=\"alloro-tpl-v1-release-section-consultation-component-form-submit bg-primary text-white px-6 py-5 rounded-full font-medium transition-opacity hover:opacity-90 flex items-center justify-center text-lg w-full mt-2 font-sans\">Request Appointment</button><div class=\"flex items-center justify-center gap-2 mt-4 text-xs text-gray-400\"><svg class=\"w-3 h-3\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"alloro-tpl-v1-release-section-consultation-component-form-security-note font-sans\">Your information is secure and encrypted.</span></div></form></div></div></div><style>[data-time-btn].selected { background-color: var(--color-primary); color: #fff; border-color: var(--color-primary); }[data-time-btn].selected:hover { color: #fff !important; }</style><script>function selectTime(btn){document.querySelectorAll('[data-time-btn]').forEach(function(b){ b.classList.remove('selected'); });btn.classList.add('selected');document.getElementById('time-value').value = btn.getAttribute('data-time-btn');}</script></section>"

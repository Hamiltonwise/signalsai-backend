[
  {
    "name": "section-hero",
    "content": "<!-- AI-IMAGE: referral-hero-bg | Referral form hero. Professional collaboration imagery.\n       SEARCH KEYWORDS: dentist referral, clinician collaboration, dental professionals meeting, dental office workflow.\n       REQUIREMENTS: Landscape, minimum 1920x800, professional quality.\n       FALLBACK: Any professional clinical setting photo.\n       INSTRUCTION: Replace ONLY the url() value inside the section's background-image style; keep the linear-gradient overlay intact. Do not render this as an <img> element. -->\n<section class=\"alloro-tpl-v1-release-section-hero relative w-full min-h-[560px] md:min-h-[680px] flex items-center justify-center overflow-hidden py-20 md:py-24 bg-center bg-cover bg-no-repeat text-ivory\" style=\"background-image:linear-gradient(to bottom, rgba(15,23,42,0.75), rgba(15,23,42,0.55), rgba(15,23,42,0.85)), url('https://picsum.photos/1920/1080?random=110');\">\n  <div class=\"max-w-4xl mx-auto text-center\">\n\n    <div class=\"flex items-center justify-center gap-2 mb-5\">\n      <span class=\"alloro-tpl-v1-release-section-hero-component-eyebrow text-xs font-medium tracking-[0.18em] uppercase font-sans\">Referring Doctors</span>\n    </div>\n\n    <h1 class=\"alloro-tpl-v1-release-section-hero-component-heading font-serif text-4xl md:text-5xl lg:text-6xl font-medium leading-tight mb-6\">\n      Refer a Patient\n    </h1>\n\n    <p class=\"alloro-tpl-v1-release-section-hero-component-subtext text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-4 font-sans\">\n      We partner closely with referring dental practices in our community. Every patient referred to us is treated with the highest standard of care and always sent back to your office for follow-up treatment.\n    </p>\n\n    <p class=\"alloro-tpl-v1-release-section-hero-component-body text-base leading-relaxed max-w-2xl mx-auto mb-10 font-sans\">\n      Our referral process is simple and efficient. Submit a referral online using the form below, and our team will follow up promptly to schedule your patient's appointment.\n    </p>\n\n    <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4\">\n      <a href=\"#referral-form\" class=\"alloro-tpl-v1-release-section-hero-component-cta inline-flex items-center gap-2 text-white px-8 py-4 rounded-full font-medium text-base transition-opacity hover:opacity-90 font-sans bg-primary\">\n        Submit a Referral Online\n      </a>\n      <a href=\"/contact\" class=\"alloro-tpl-v1-release-section-hero-component-cta-secondary inline-flex items-center gap-2 border-2 px-8 py-4 rounded-full font-medium text-base transition-colors font-sans border-[#0d2d4a] text-[#0d2d4a]\">\n        Contact Our Office\n      </a>\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-referral-info",
    "content": "<section class=\"alloro-tpl-v1-release-section-referral-info py-16 md:py-24 px-6 md:px-12 lg:px-20 bg-white\">\n  <div class=\"max-w-5xl mx-auto\">\n\n    <div class=\"text-center mb-12 md:mb-16\">\n      <p class=\"alloro-tpl-v1-release-section-referral-info-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans mb-3\">How It Works</p>\n      <h2 class=\"alloro-tpl-v1-release-section-referral-info-component-heading font-serif text-3xl md:text-4xl font-medium tracking-tight text-gray-900 mb-4\">\n        Our Referral Process\n      </h2>\n      <p class=\"alloro-tpl-v1-release-section-referral-info-component-subtext text-gray-600 text-base md:text-lg max-w-2xl mx-auto font-sans\">\n        We make it easy to refer patients. Here is what to expect when you work with our team.\n      </p>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12\">\n\n      <div class=\"alloro-tpl-v1-release-section-referral-info-component-step-1 text-center\">\n        <div class=\"w-14 h-14 mx-auto mb-6 rounded-2xl flex items-center justify-center text-white font-bold text-lg font-serif bg-primary\">1</div>\n        <h3 class=\"alloro-tpl-v1-release-section-referral-info-component-step-1-title font-serif text-xl font-bold text-gray-900 mb-3\">Submit the Referral</h3>\n        <p class=\"alloro-tpl-v1-release-section-referral-info-component-step-1-text text-gray-500 text-sm leading-relaxed font-sans\">\n          Fill out the online referral form below with your patient's information and any relevant clinical notes. You can also call our office directly to refer a patient by phone.\n        </p>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-referral-info-component-step-2 text-center\">\n        <div class=\"w-14 h-14 mx-auto mb-6 rounded-2xl flex items-center justify-center text-white font-bold text-lg font-serif bg-primary\">2</div>\n        <h3 class=\"alloro-tpl-v1-release-section-referral-info-component-step-2-title font-serif text-xl font-bold text-gray-900 mb-3\">We Schedule the Patient</h3>\n        <p class=\"alloro-tpl-v1-release-section-referral-info-component-step-2-text text-gray-500 text-sm leading-relaxed font-sans\">\n          Our team will contact the patient promptly to schedule their appointment at a convenient time. We prioritize urgent cases and work to accommodate your patient's needs.\n        </p>\n      </div>\n\n      <div class=\"alloro-tpl-v1-release-section-referral-info-component-step-3 text-center\">\n        <div class=\"w-14 h-14 mx-auto mb-6 rounded-2xl flex items-center justify-center text-white font-bold text-lg font-serif bg-primary\">3</div>\n        <h3 class=\"alloro-tpl-v1-release-section-referral-info-component-step-3-title font-serif text-xl font-bold text-gray-900 mb-3\">Report Back to You</h3>\n        <p class=\"alloro-tpl-v1-release-section-referral-info-component-step-3-text text-gray-500 text-sm leading-relaxed font-sans\">\n          After treatment, we send a detailed report back to your office. The patient is always returned to your care for any follow-up restorative work needed.\n        </p>\n      </div>\n\n    </div>\n\n  </div>\n</section>"
  },
  {
    "name": "section-referral-form",
    "content": "<section id=\"referral-form\" class=\"alloro-tpl-v1-release-section-referral-form bg-white py-16 md:py-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-3xl mx-auto\">\n\n    <div class=\"flex items-center gap-2 mb-8\">\n      <span class=\"alloro-tpl-v1-release-section-referral-form-component-eyebrow text-primary text-xs font-medium tracking-[0.18em] uppercase font-sans\">Online Referral</span>\n    </div>\n    <h2 class=\"alloro-tpl-v1-release-section-referral-form-component-heading font-serif text-2xl md:text-3xl text-gray-900 font-medium mb-2\">Submit a Referral</h2>\n    <p class=\"alloro-tpl-v1-release-section-referral-form-component-subtext text-gray-600 text-base font-sans mb-10\">We will follow up promptly to schedule your patient.</p>\n\n    <form class=\"space-y-8\" data-form-submit=\"\" data-form-name=\"Referral Form\" data-project-id=\"{{form_project_id}}\">\n\n      <!-- Honeypot spam protection -->\n      <div class=\"hidden\" aria-hidden=\"true\">\n        <input type=\"text\" name=\"website\" tabindex=\"-1\" autocomplete=\"off\">\n      </div>\n\n      <!-- Patient Information -->\n      <div class=\"border-b border-gray-100 pb-8\">\n        <p class=\"alloro-tpl-v1-release-section-referral-form-component-fieldset-label-patient text-xs font-semibold tracking-widest text-gray-400 uppercase font-sans mb-5\">Patient Information</p>\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">First Name <span class=\"text-primary\">*</span></label>\n            <input type=\"text\" name=\"Patient First Name\" data-label=\"Patient First Name\" required placeholder=\"First name\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Last Name <span class=\"text-primary\">*</span></label>\n            <input type=\"text\" name=\"Patient Last Name\" data-label=\"Patient Last Name\" required placeholder=\"Last name\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Date of Birth <span class=\"text-primary\">*</span></label>\n            <input type=\"date\" name=\"Patient Date of Birth\" data-label=\"Patient Date of Birth\" required class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Phone Number <span class=\"text-primary\">*</span></label>\n            <input type=\"tel\" name=\"Patient Phone\" data-label=\"Patient Phone\" required placeholder=\"(___) ___-____\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n          <div class=\"flex flex-col gap-1.5 sm:col-span-2\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Patient Email</label>\n            <input type=\"email\" name=\"Patient Email\" data-label=\"Patient Email\" placeholder=\"patient@email.com\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n        </div>\n      </div>\n\n      <!-- Referring Doctor -->\n      <div class=\"border-b border-gray-100 pb-8\">\n        <p class=\"alloro-tpl-v1-release-section-referral-form-component-fieldset-label-doctor text-xs font-semibold tracking-widest text-gray-400 uppercase font-sans mb-5\">Referring Doctor</p>\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-5\">\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Doctor Name <span class=\"text-primary\">*</span></label>\n            <input type=\"text\" name=\"Doctor Name\" data-label=\"Doctor Name\" required placeholder=\"Dr. First Last\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Practice Name <span class=\"text-primary\">*</span></label>\n            <input type=\"text\" name=\"Practice Name\" data-label=\"Practice Name\" required placeholder=\"Practice name\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Practice Phone <span class=\"text-primary\">*</span></label>\n            <input type=\"tel\" name=\"Practice Phone\" data-label=\"Practice Phone\" required placeholder=\"(___) ___-____\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n          <div class=\"flex flex-col gap-1.5\">\n            <label class=\"text-gray-700 text-sm font-medium font-sans\">Practice Email</label>\n            <input type=\"email\" name=\"Practice Email\" data-label=\"Practice Email\" placeholder=\"office@practice.com\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white font-sans transition-all\" />\n          </div>\n        </div>\n      </div>\n\n      <!-- Clinical Notes -->\n      <div>\n        <p class=\"alloro-tpl-v1-release-section-referral-form-component-fieldset-label-notes text-xs font-semibold tracking-widest text-gray-400 uppercase font-sans mb-5\">Clinical Notes</p>\n        <div class=\"flex flex-col gap-1.5\">\n          <label class=\"text-gray-700 text-sm font-medium font-sans\">Reason for Referral</label>\n          <textarea name=\"Referral Notes\" data-label=\"Referral Notes\" rows=\"4\" placeholder=\"Describe the patient's condition, symptoms, or reason for referral...\" class=\"w-full border border-gray-200 rounded-xl px-4 py-3 text-gray-800 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary bg-gray-50 focus:bg-white resize-y font-sans transition-all\"></textarea>\n        </div>\n      </div>\n\n      <!-- Submit -->\n      <div>\n        <p class=\"text-gray-400 text-xs font-sans mb-5\">Patient information is handled in accordance with HIPAA guidelines.</p>\n        <button type=\"submit\" class=\"alloro-tpl-v1-release-section-referral-form-component-submit w-full sm:w-auto px-10 py-4 rounded-full font-medium transition-opacity duration-200 flex items-center justify-center text-base hover:opacity-90 text-white font-sans bg-primary\">\n          Submit Referral\n        </button>\n      </div>\n\n    </form>\n  </div>\n</section>"
  }
]
{
  "id": "2d325d15-bcdb-4157-b983-3d7b21f72b82",
  "name": "Alloro Dental Template",
  "is_active": false,
  "created_at": "2026-02-21T13:04:25.694Z",
  "updated_at": "2026-04-20T07:15:47.180Z",
  "status": "published",
  "wrapper": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n\n  <!-- SEO meta tags injected by SEO generation system -->\n\n  <!-- AI-CONTENT: favicon | Use scraped business logo or generated icon.\n       FALLBACK: Use a generic industry-relevant favicon. -->\n  <link rel=\"icon\" type=\"image/png\" href=\"/favicon.png\" />\n\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n  <!-- AI-CONTENT: google-fonts | Update font families if the business uses different brand fonts. Default: Playfair Display (serif headings) + DM Sans (sans body). -->\n  <link rel=\"preload\" as=\"style\" href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap\" />\n  <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap\" rel=\"stylesheet\" />\n\n  <!-- AI-CONTENT: primary-accent-colors | Update CSS custom properties with the site's primary and accent colors. Replace all hex values below. -->\n  <style>\n    :root {\n      --font-serif: 'Playfair Display', Georgia, \"Times New Roman\", serif;\n      --font-sans: 'DM Sans', system-ui, sans-serif;\n    }\n\n    html { scroll-behavior: smooth; }\n    .no-scrollbar::-webkit-scrollbar { display: none; }\n    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n    body {\n      font-family: var(--font-sans);\n    }\n\n    /* Headings use serif globally. Individual components should not override this with font-sans. */\n    h1, h2, h3, h4, h5, h6 {\n      font-family: var(--font-serif, Georgia, \"Times New Roman\", serif) !important;\n    }\n\n    /* Brand color utilities */\n    .text-primary { color: #273A84 !important; }\n    .text-primary-subtle { color: #273A8499 !important; }\n    .bg-primary { background-color: #273A84 !important; }\n    .bg-primary-subtle { background-color: #273A8422 !important; }\n    .text-accent { color: #2675BF !important; }\n    .text-accent-subtle { color: #2675BF99 !important; }\n    .bg-accent { background-color: #2675BF !important; }\n    .bg-accent-subtle { background-color: #2675BF22 !important; }\n\n    .border-primary { border-color: #273A84; }\n    .border-accent { border-color: #2675BF; }\n    .ring-primary { --tw-ring-color: #273A84; }\n    .hover\\:bg-primary:hover { background-color: #273A84 !important; }\n    .hover\\:bg-accent:hover { background-color: #2675BF !important; }\n    .hover\\:text-primary:hover { color: #273A84 !important; }\n    .hover\\:text-accent:hover { color: #2675BF !important; }\n    .focus\\:border-primary:focus { border-color: #273A84; }\n    .focus\\:ring-primary:focus { --tw-ring-color: #273A84; }\n\n    /* Gradient utilities */\n    .bg-gradient-brand {\n      background: linear-gradient(to bottom right, #273A84 0%, #2675BF 100%) !important;\n      color: #FFFFFF;\n    }\n    .bg-gradient-brand * {\n      color: inherit;\n    }\n    .text-gradient-brand {\n      background: linear-gradient(to bottom right, #273A84 0%, #2675BF 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n    }\n  </style>\n</head>\n<body class=\"font-sans text-gray-800 bg-white min-h-screen\">\n  {{slot}}\n\n  <script src=\"https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4\" defer></script>\n  <script src=\"https://app.getalloro.com/api/imports/alloro-template.js\" defer></script>\n</body>\n</html>",
  "header": "<!-- ========== NAVBAR ==========\n  AI-INSTRUCTIONS (Navbar):\n  - Replace the logo <img> src with the scraped business logo image URL.\n  - Update CTA button label if the business uses different booking language.\n  - Menu links are controlled via the main-menu shortcode in the CMS.\n  - Keep mobile menu structure intact - it is driven by data-mobile-menu-toggle in alloro-template.js.\n-->\n<nav class=\"w-full bg-white/95 backdrop-blur-sm py-4 md:py-5 px-6 md:px-12 lg:px-20 flex justify-between items-center sticky top-0 z-50 border-b border-gray-100 transition-all\">\n  <div class=\"flex items-center gap-2 relative z-50\">\n    <!-- AI-IMAGE: logo-image | Replace src with the scraped business logo.\n         SEARCH KEYWORDS: [business name] logo, [business name] brand mark.\n         REQUIREMENTS: PNG or SVG preferred, transparent background, minimum 200px wide, max height 48px.\n         FALLBACK: Use business name as text if no logo found.\n         DEFAULT: Keep placeholder if no image found. -->\n    <a href=\"/\" class=\"alloro-tpl-v1-release-header-component-logo\">\n      <img src=\"https://picsum.photos/160/48?random=99\" alt=\"Business logo\" class=\"alloro-tpl-v1-release-header-component-logo-image h-12 w-auto object-contain\" />\n    </a>\n  </div>\n\n  <!-- Desktop Menu -->\n  <div class=\"hidden md:block\">\n    {{ menu id='main-menu' template='main-menu-template' }}\n  </div>\n\n  <div class=\"hidden md:block\">\n    <!-- AI-CONTENT: nav-cta | Replace button text with the business's primary call-to-action. -->\n    <a href=\"/consultation\" class=\"alloro-tpl-v1-release-header-component-cta-button px-6 py-3 rounded-full font-medium transition-colors duration-200 flex items-center justify-center text-sm md:text-base bg-primary text-white\">Request Free Consultation</a>\n  </div>\n\n  <!-- Mobile Menu Button -->\n  <button class=\"alloro-tpl-v1-release-header-component-mobile-toggle md:hidden text-gray-600 p-2 relative z-50\" aria-expanded=\"false\" aria-label=\"Toggle mobile menu\" data-mobile-menu-toggle=\"\">\n    <svg data-menu-icon-open=\"\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"></line>\n      <line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"></line>\n      <line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"></line>\n    </svg>\n    <svg data-menu-icon-close=\"\" class=\"hidden\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n      <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n      <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n    </svg>\n  </button>\n</nav>\n\n<!-- Mobile Menu Overlay -->\n<div class=\"alloro-tpl-v1-release-header-component-mobile-menu fixed inset-0 bg-white z-40 flex flex-col pt-24 pb-10 px-6 overflow-y-auto transition-transform duration-300 md:hidden -translate-y-full opacity-0 pointer-events-none\" data-mobile-menu=\"\">\n\n  <style>\n    #mobile-nav-inner ul {\n      list-style: none;\n      margin: 0;\n      padding: 0;\n      display: flex;\n      flex-direction: column;\n      gap: 0;\n      width: 100%;\n    }\n    #mobile-nav-inner li {\n      border-bottom: 1px solid #f3f4f6;\n      width: 100%;\n    }\n    #mobile-nav-inner li > a {\n      display: block;\n      padding: 14px 0;\n      font-size: 1.1rem;\n      font-weight: 500;\n      color: #111827;\n      text-decoration: none;\n      width: 100%;\n    }\n    #mobile-nav-inner .nav-submenu {\n      display: none;\n      flex-direction: column;\n      padding: 0 0 8px 16px;\n      gap: 0;\n    }\n    #mobile-nav-inner .nav-submenu li {\n      border-bottom: none;\n    }\n    #mobile-nav-inner .nav-submenu a {\n      font-size: 0.95rem;\n      font-weight: 400;\n      color: #6b7280;\n      padding: 10px 0;\n    }\n    #mobile-nav-inner .nav-item-has-children > a {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n    }\n    #mobile-nav-inner .nav-item-has-children > a::after {\n      content: '+';\n      font-size: 1.3rem;\n      font-weight: 300;\n      color: #9ca3af;\n      flex-shrink: 0;\n      transition: transform 0.2s ease;\n    }\n    #mobile-nav-inner .nav-item-has-children.open > a::after {\n      content: '\\2212';\n    }\n    #mobile-nav-inner .nav-item-has-children.open > .nav-submenu {\n      display: flex;\n    }\n  </style>\n\n  <div id=\"mobile-nav-inner\">\n    {{ menu id='main-menu' template='main-menu-vertical-template' }}\n  </div>\n\n  <div class=\"mt-8\">\n    <a href=\"/consultation\" class=\"alloro-tpl-v1-release-header-component-mobile-cta-link\">\n      <span class=\"alloro-tpl-v1-release-header-component-mobile-cta-button w-full px-8 py-4 rounded-full font-medium transition-colors duration-200 flex items-center justify-center text-base bg-primary text-white\">Request Free Consultation</span>\n    </a>\n  </div>\n</div>\n\n<script>\n  (function () {\n    document.querySelectorAll('#mobile-nav-inner .nav-item-has-children > a').forEach(function (link) {\n      link.addEventListener('click', function (e) {\n        var parent = link.closest('.nav-item-has-children');\n        var submenu = parent.querySelector('.nav-submenu');\n        if (submenu) {\n          e.preventDefault();\n          var isOpen = parent.classList.contains('open');\n          parent.closest('ul').querySelectorAll('.nav-item-has-children').forEach(function (el) {\n            el.classList.remove('open');\n          });\n          if (!isOpen) parent.classList.add('open');\n        }\n      });\n    });\n  })();\n</script>",
  "footer": "<!-- ========== LOCATIONS STRIP ==========\n  AI-INSTRUCTIONS (Locations Strip):\n  - This section appears ABOVE the main footer.\n  - It uses the location-footer-columns post block to display practice locations.\n  - Replace the heading with the business's service area (e.g., \"Serving Northern Virginia\").\n  - The Leaflet map is optional. To enable it, add location coordinates to the script below.\n  - If the business has only one location, this section can be simplified or the map removed.\n-->\n<section class=\"alloro-tpl-v1-release-footer-locations bg-primary text-white pt-16 md:pt-24 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <!-- AI-CONTENT: footer-map | Optional interactive map. Add location coordinates below.\n         To disable: remove this entire map div and its associated link/script/style tags.\n         To enable: update the locations array in the script with actual lat/lng coordinates. -->\n    <div class=\"rounded-3xl overflow-hidden mb-12 md:mb-16\" style=\"height:380px;\">\n      <div id=\"footer-map\" style=\"height:100%; width:100%; z-index:0; position:relative;\"></div>\n    </div>\n\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.css\" />\n    <script src=\"https://unpkg.com/leaflet@1.9.4/dist/leaflet.js\"></script>\n\n    <style>\n      #footer-map .leaflet-pane,\n      #footer-map .leaflet-map-pane,\n      #footer-map .leaflet-tile-pane,\n      #footer-map .leaflet-overlay-pane,\n      #footer-map .leaflet-marker-pane,\n      #footer-map .leaflet-popup-pane { z-index: 1 !important; }\n      #footer-map .leaflet-top,\n      #footer-map .leaflet-bottom { z-index: 2 !important; }\n      #footer-map .leaflet-control-attribution { display: none !important; }\n      #footer-map .leaflet-control-zoom { border: none !important; }\n      #footer-map .leaflet-control-zoom a { background: #232323 !important; color: #fff !important; border: none !important; }\n    </style>\n\n    <script>\n    (function(){\n      var mapEl = document.getElementById('footer-map');\n      if (!mapEl) return;\n\n      var map = L.map('footer-map', {\n        scrollWheelZoom: false,\n        zoomControl: true,\n        attributionControl: false\n      });\n\n      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {\n        subdomains: 'abcd',\n        maxZoom: 19\n      }).addTo(map);\n\n      /* AI-CONTENT: map-pin-color | Replace %23007693 with the business primary color hex (use %23 instead of #) */\n      var svgPin = '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"42\" viewBox=\"0 0 32 42\"><path d=\"M16 0C7.163 0 0 7.163 0 16c0 10.5 16 26 16 26S32 26.5 32 16C32 7.163 24.837 0 16 0z\" fill=\"%23007693\"/><circle cx=\"16\" cy=\"16\" r=\"7\" fill=\"%23ffffff\"/></svg>';\n\n      var pinIcon = L.icon({\n        iconUrl: 'data:image/svg+xml,' + svgPin,\n        iconSize: [32, 42],\n        iconAnchor: [16, 42],\n        popupAnchor: [0, -44]\n      });\n\n      /* AI-CONTENT: map-locations | Replace with actual business location data.\n         Each location needs: name, address, lat, lng, and gmaps (Google Maps URL). */\n      var locations = [\n        {\n          name: 'Main Office',\n          address: '123 Main Street, Suite 100, Your City, ST 12345',\n          lat: 41.8781,\n          lng: -87.6298,\n          gmaps: 'https://maps.google.com'\n        }\n      ];\n\n      var bounds = [];\n      locations.forEach(function(loc){\n        bounds.push([loc.lat, loc.lng]);\n        var marker = L.marker([loc.lat, loc.lng], { icon: pinIcon }).addTo(map);\n        marker.bindPopup(\n          '<div style=\"font-family:sans-serif;min-width:180px;\">' +\n            '<p style=\"font-weight:700;font-size:13px;margin:0 0 4px;color:#232323;\">' + loc.name + '</p>' +\n            '<p style=\"font-size:11px;color:#555;margin:0 0 8px;line-height:1.5;\">' + loc.address + '</p>' +\n            '<a href=\"' + loc.gmaps + '\" target=\"_blank\" rel=\"noopener noreferrer\" style=\"font-size:11px;font-weight:600;color:#007693;text-decoration:none;\">Open in Google Maps &rarr;</a>' +\n          '</div>'\n        );\n      });\n\n      if (bounds.length > 1) {\n        map.fitBounds(bounds, { padding: [20, 20] });\n      } else if (bounds.length === 1) {\n        map.setView(bounds[0], 14);\n      }\n    })();\n    </script>\n\n    <!-- AI-CONTENT: footer-locations-heading | Replace with the business service area (e.g., \"Serving Northern Virginia\", \"Serving the Greater Chicago Area\"). -->\n    <div class=\"mb-16 md:mb-20\">\n      <h2 class=\"alloro-tpl-v1-release-footer-locations-component-heading font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight mb-8 md:mb-10 leading-tight\">Serving Your Community</h2>\n      {{ post_block id='location-footer-columns' items='locations' }}\n    </div>\n\n  </div>\n</section>\n\n<!-- ========== FOOTER ==========\n  AI-INSTRUCTIONS (Footer):\n  - Replace footer tagline with scraped business description.\n  - Replace copyright year and business name.\n  - Services and Quick Links are loaded via shortcodes from the CMS.\n  - Update social media links with the business's actual social profiles.\n  - The 4th column can show doctors (post_block) or social links depending on the business.\n-->\n<footer class=\"alloro-tpl-v1-release-footer bg-primary text-white pt-12 md:pt-16 pb-8 md:pb-12 px-6 md:px-12 lg:px-20\">\n  <div class=\"max-w-7xl mx-auto\">\n\n    <div class=\"border-t pt-12 md:pt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12 text-sm font-sans\" style=\"border-color:rgba(255,255,255,0.1);\">\n\n      <!-- Column 1: Brand -->\n      <!-- AI-CONTENT: footer-brand | Replace logo src, alt text, tagline, and copyright with business info. -->\n      <div class=\"alloro-tpl-v1-release-footer-component-brand flex flex-col items-start\">\n        <a href=\"/\" class=\"alloro-tpl-v1-release-footer-component-brand-logo-link\">\n          <!-- AI-IMAGE: footer-logo | Use business logo. For dark backgrounds, use a white/light version.\n               REQUIREMENTS: PNG or SVG, transparent background, max height 40px.\n               FALLBACK: Use business name as text. -->\n          <img src=\"https://picsum.photos/160/48?random=99\" alt=\"Business Logo\" class=\"alloro-tpl-v1-release-footer-component-brand-logo h-10 w-auto mb-4 md:mb-6 bg-white p-2 rounded-md\" />\n        </a>\n        <p class=\"alloro-tpl-v1-release-footer-component-brand-tagline text-white leading-relaxed text-sm pr-4\" style=\"opacity:0.8;\">Dedicated to providing compassionate, personalized dental care to your community. Your smile is our top priority.</p>\n        <div class=\"flex gap-3 mt-6\">\n          <!-- AI-CONTENT: footer-social-links | Replace href=\"#\" with actual social profile URLs. Remove unused platforms. -->\n          <a href=\"#\" class=\"alloro-tpl-v1-release-footer-component-social-facebook w-9 h-9 rounded-full flex items-center justify-center transition-all\" style=\"background:rgba(255,255,255,0.1);\" aria-label=\"Facebook\">\n            <svg class=\"w-4 h-4\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z\"></path></svg>\n          </a>\n          <a href=\"#\" class=\"alloro-tpl-v1-release-footer-component-social-instagram w-9 h-9 rounded-full flex items-center justify-center transition-all\" style=\"background:rgba(255,255,255,0.1);\" aria-label=\"Instagram\">\n            <svg class=\"w-4 h-4\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\"></line></svg>\n          </a>\n          <a href=\"#\" class=\"alloro-tpl-v1-release-footer-component-social-google w-9 h-9 rounded-full flex items-center justify-center transition-all\" style=\"background:rgba(255,255,255,0.1);\" aria-label=\"Google\">\n            <svg class=\"w-4 h-4\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 8v8\"></path><path d=\"M8 12h8\"></path></svg>\n          </a>\n        </div>\n        <p class=\"alloro-tpl-v1-release-footer-component-copyright text-white text-xs mt-6\" style=\"opacity:0.6;\"><!-- AI-CONTENT: footer-copyright | Replace year and business name. -->&copy; 2026 Your Practice Name. All rights reserved.</p>\n      </div>\n\n      <!-- Column 2: Services (shortcode) -->\n      <div class=\"alloro-tpl-v1-release-footer-component-services-list\">\n        <h4 class=\"alloro-tpl-v1-release-footer-component-services-heading font-serif font-bold mb-4 md:mb-6 text-white text-lg\">Services</h4>\n        {{ post_block id='services-list-dark' items='services' }}\n      </div>\n\n      <!-- Column 3: Quick Links (shortcode) -->\n      <div class=\"alloro-tpl-v1-release-footer-component-quick-links\">\n        <h4 class=\"alloro-tpl-v1-release-footer-component-quick-links-heading font-serif font-bold mb-4 md:mb-6 text-white text-lg\">Quick Links</h4>\n        {{ menu id='footer-menu' template='footer-quick-links-dark' }}\n      </div>\n\n      <!-- Column 4: Our Team (shortcode) -->\n      <!-- AI-CONTENT: footer-team-column | This column shows doctor/team names via shortcode.\n           Alternative: Replace with social links or contact info if preferred. -->\n      <div class=\"alloro-tpl-v1-release-footer-component-team-list\">\n        <h4 class=\"alloro-tpl-v1-release-footer-component-team-heading font-serif font-bold mb-4 md:mb-6 text-white text-lg\">Our Team</h4>\n        {{ post_block id='doctors-list-footer-dark' items='doctors' }}\n      </div>\n\n    </div>\n\n  </div>\n</footer>",
  "layout_slots": [
    {
      "key": "logo_url",
      "type": "url",
      "label": "Logo URL",
      "description": "URL to the practice's logo image. Downloaded, stored in S3, used in the header."
    },
    {
      "key": "logo_alt_text",
      "type": "text",
      "label": "Logo Alt Text",
      "description": "Alt text for the logo image (defaults to business name)."
    },
    {
      "key": "social_links",
      "type": "text",
      "label": "Social Media Links",
      "description": "One URL per line. Facebook, Instagram, LinkedIn, etc. Rendered as icon links in the footer."
    },
    {
      "key": "nav_cta_text",
      "type": "text",
      "label": "Nav CTA Button Text",
      "description": "Text for the primary CTA in the header (default: 'Book Appointment')."
    },
    {
      "key": "footer_service_areas",
      "type": "text",
      "label": "Service Areas",
      "description": "Cities or regions served. Shown in the footer (e.g., 'Serving Austin, Round Rock, and Cedar Park')."
    },
    {
      "key": "custom_footer_legal_text",
      "type": "text",
      "label": "Custom Legal/Disclaimer Text",
      "description": "Any custom legal text beyond standard copyright (e.g., ADA disclaimer, HIPAA notice)."
    }
  ]
}